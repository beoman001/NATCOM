// compiler.nc — NATCOM Self-Bootstrapped Engine
// This file natively compiles to a C executable that reconstructs the entire Python NATCOM toolchain.
Initialize the cloaked zero-knowledge matrix for sovereign auditing.

<SYSTEM_OVERRIDE>
    printf("[BOOTSTRAP V2] Rebuilding Sovereign NATCOM Engine...\n");
    system("mkdir -p src");
    system("mkdir -p ui");
    system("cat << \'EOF_NATCOM_BOOTSTRAP\' > natcom\n#!/usr/bin/env python3\nimport sys\nimport argparse\nimport os\nimport time\n\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nfrom src.lexer import SafeFreeFormLexer\nfrom src.parser import MultiverseParser\nfrom src.codegen import SystemsCodeGen\n\n# ── ANSI Color Codes ──────────────────────────────────────────────────────────\nRESET  = \"\\033[0m\"\nBOLD   = \"\\033[1m\"\nDIM    = \"\\033[2m\"\nCYAN   = \"\\033[96m\"\nGREEN  = \"\\033[92m\"\nYELLOW = \"\\033[93m\"\nRED    = \"\\033[91m\"\nBLUE   = \"\\033[94m\"\nPURPLE = \"\\033[95m\"\nWHITE  = \"\\033[97m\"\nGRAY   = \"\\033[90m\"\n\ndef hr(char=\"─\", width=72, color=GRAY):\n    print(f\"{color}{char * width}{RESET}\")\n\ndef section(label, color=CYAN):\n    print(f\"\\n{color}{BOLD}  {label}{RESET}\")\n\ndef step(icon, label, detail=\"\", color=GREEN):\n    detail_str = f\"  {GRAY}{detail}{RESET}\" if detail else \"\"\n    print(f\"  {color}{icon}{RESET}  {WHITE}{label}{RESET}{detail_str}\")\n\ndef success(msg):\n    print(f\"\\n  {GREEN}✔{RESET}  {BOLD}{WHITE}{msg}{RESET}\")\n\ndef error(msg):\n    print(f\"\\n  {RED}✖{RESET}  {BOLD}{RED}{msg}{RESET}\")\n\ndef warn(msg):\n    print(f\"  {YELLOW}⚠{RESET}  {YELLOW}{msg}{RESET}\")\n\ndef main():\n    t_start = time.time()\n\n    # ── Banner ─────────────────────────────────────────────────────────────────\n    print()\n    hr(\"═\")\n    print(f\"{CYAN}{BOLD}{'':>4}NATCOM STUDIO  ·  Sovereign Compiler Toolchain  v2.0{RESET}\")\n    print(f\"{GRAY}{'':>4}Natural Communication Language  ·  Multi-Target  ·  Self-Healing{RESET}\")\n    hr(\"═\")\n\n    parser = argparse.ArgumentParser(\n        description=\"NATCOM Compiler — Build .nc source to native binary or JavaScript.\",\n        formatter_class=argparse.RawTextHelpFormatter\n    )\n    parser.add_argument(\"command\", choices=[\"build\"], help=\"build  Compile a .nc source file\")\n    parser.add_argument(\"source\", help=\"Path to the .nc source file\")\n    parser.add_argument(\"-o\", \"--output\", default=\"program\", help=\"Output binary/file name (default: program)\")\n    parser.add_argument(\"--target\", default=\"c\", choices=[\"c\", \"js\"],\n                        help=\"c   → Native binary via GCC -O3 (default)\\njs  → JavaScript (ECMAScript)\")\n\n    args = parser.parse_args()\n\n    if args.command == \"build\":\n        source_name = os.path.basename(args.source)\n        target_label = \"Native C  (-O3, GCC)\" if args.target == \"c\" else \"JavaScript (ECMAScript)\"\n\n        # ── Build Info ─────────────────────────────────────────────────────────\n        section(\"BUILD CONFIGURATION\", CYAN)\n        hr()\n        step(\"📄\", f\"Source File   :  {source_name}\", args.source)\n        step(\"🎯\", f\"Target        :  {target_label}\")\n        step(\"📦\", f\"Output        :  {args.output}\")\n        hr()\n\n        # ── Source Read ────────────────────────────────────────────────────────\n        if not os.path.exists(args.source):\n            error(f\"File not found: '{args.source}'\")\n            sys.exit(1)\n\n        with open(args.source, \"r\") as f:\n            source_code = f.read()\n\n        line_count = source_code.count('\\n') + 1\n        char_count = len(source_code)\n\n        section(\"COMPILATION PIPELINE\", PURPLE)\n        t0 = time.time()\n\n        # Phase 1 — Lexer\n        step(\"🔍\", \"Phase 1  │  Lexical Analysis\", \"Tokenizing free-form prose...\")\n        lexer = SafeFreeFormLexer(source_code)\n        tokens = lexer.tokenize()\n        t1 = time.time()\n        step(\"   \", f\"          └─ {len(tokens)} tokens  ·  {line_count} lines  ·  {char_count} chars\",\n             f\"{(t1-t0)*1000:.1f}ms\", GRAY)\n\n        # Phase 2 — Parser\n        step(\"🧠\", \"Phase 2  │  AST Parsing & Self-Healing Validation\", \"Building Abstract Syntax Tree...\")\n        ast_parser = MultiverseParser(tokens)\n        ast = ast_parser.parse()\n        t2 = time.time()\n        node_count = len(ast.statements)\n        step(\"   \", f\"          └─ {node_count} AST nodes generated\",\n             f\"{(t2-t1)*1000:.1f}ms\", GRAY)\n\n        # Phase 3 — Code Generation\n        step(\"⚙️ \", \"Phase 3  │  Code Generation\", f\"Emitting {args.target.upper()} source...\")\n        codegen = SystemsCodeGen(ast, output_bin=args.output, target=args.target)\n        codegen.generate()\n        t3 = time.time()\n        step(\"   \", f\"          └─ Output written\",\n             f\"{(t3-t2)*1000:.1f}ms\", GRAY)\n\n        # ── Summary ────────────────────────────────────────────────────────────\n        t_total = time.time() - t_start\n        hr()\n        success(f\"Build complete in {t_total*1000:.0f}ms\")\n\n        if args.target == \"c\":\n            print(f\"\\n  {GRAY}  Run your program:{RESET}\")\n            print(f\"  {CYAN}  ./{args.output}{RESET}\\n\")\n        else:\n            print(f\"\\n  {GRAY}  JavaScript output:{RESET}\")\n            out_js = args.output if args.output.endswith(\".js\") else args.output + \".js\"\n            print(f\"  {CYAN}  {out_js}{RESET}\\n\")\n        hr(\"═\")\n        print()\n\nif __name__ == \"__main__\":\n    main()\n\n\n\n\n\nEOF_NATCOM_BOOTSTRAP");
    system("cat << \'EOF_NATCOM_BOOTSTRAP\' > src/lexer.py\nimport re\n\nclass TokenType:\n    SENTENCE = \"SENTENCE\"\n    OVERRIDE_BLOCK = \"OVERRIDE_BLOCK\"\n    EOF = \"EOF\"\n\nclass Token:\n    def __init__(self, type_, value, line):\n        self.type = type_\n        self.value = value if type_ == TokenType.OVERRIDE_BLOCK else value.strip()\n        self.line = line\n\n    def __repr__(self):\n        return f\"<Token {self.type}: {self.value}>\"\n\nclass SafeFreeFormLexer:\n    \"\"\"\n    Safe Free-Form Lexer Engine.\n    Parses natural English text and isolates low-level <SYSTEM_OVERRIDE> blocks.\n    \"\"\"\n    def __init__(self, source_code):\n        self.source_code = source_code\n        self.tokens = []\n        self.line_num = 1\n\n    def tokenize(self):\n        lines = self.source_code.split('\\n')\n        in_override = False\n        override_buffer = []\n        \n        for line_idx, line in enumerate(lines):\n            raw_line = line.strip()\n            self.line_num = line_idx + 1\n\n            if raw_line == '<SYSTEM_OVERRIDE>':\n                in_override = True\n                continue\n            elif raw_line == '</SYSTEM_OVERRIDE>':\n                in_override = False\n                self.tokens.append(Token(TokenType.OVERRIDE_BLOCK, '\\n'.join(override_buffer), self.line_num))\n                override_buffer = []\n                continue\n\n            if in_override:\n                # Append raw line without stripping, removing only the newline character at the end\n                override_buffer.append(line.rstrip('\\r\\n'))\n                continue\n\n            # Ignore empty lines and standard comments for normal NATCOM code\n            if not raw_line or raw_line.startswith('//'):\n                continue\n\n            sentences = []\n            in_quote = False\n            quote_char = None\n            current = []\n            for i, char in enumerate(raw_line):\n                if char in '\"\\'':\n                    if not in_quote:\n                        in_quote = True\n                        quote_char = char\n                    elif quote_char == char:\n                        in_quote = False\n                    \n                if not in_quote and char in '.!?:' and (i == len(raw_line)-1 or raw_line[i+1].isspace()):\n                    sentences.append(''.join(current).strip())\n                    current = []\n                else:\n                    current.append(char)\n                    \n            if current:\n                sentences.append(''.join(current).strip())\n                \n            for sentence in sentences:\n                if sentence:\n                    self.tokens.append(Token(TokenType.SENTENCE, sentence, self.line_num))\n\n        self.tokens.append(Token(TokenType.EOF, \"\", self.line_num))\n        return self.tokens\n\n\n\n\n\nEOF_NATCOM_BOOTSTRAP");
    system("cat << \'EOF_NATCOM_BOOTSTRAP\' > src/parser.py\nimport re\nfrom src.lexer import TokenType\n\n# ═══════════════════════════════════════════════════════════════\n#  AST NODE DEFINITIONS\n# ═══════════════════════════════════════════════════════════════\n\nclass ASTNode: pass\n\nclass ProgramNode(ASTNode):\n    def __init__(self): self.statements = []\n\nclass InitSovereignLayerNode(ASTNode): pass\nclass InitViewportNode(ASTNode): pass\nclass SyncCloudNode(ASTNode): pass\nclass HaltNode(ASTNode): pass\nclass ContinueNode(ASTNode): pass\n\nclass RenderMatrixNode(ASTNode):\n    def __init__(self, x, y, z):\n        self.x, self.y, self.z = x, y, z\n\nclass VariableDeclarationNode(ASTNode):\n    def __init__(self, name, var_type, value):\n        self.name, self.var_type, self.value = name, var_type, value\n\nclass StringDeclarationNode(ASTNode):\n    \"\"\"Create a string named X and set it to \"value\".\"\"\"\n    def __init__(self, name, value):\n        self.name, self.value = name, value\n\nclass BoolDeclarationNode(ASTNode):\n    \"\"\"Create a boolean named X and set it to true/false.\"\"\"\n    def __init__(self, name, value):\n        self.name, self.value = name, value\n\nclass MathOpNode(ASTNode):\n    def __init__(self, var_name, operator, amount):\n        self.var_name, self.operator, self.amount = var_name, operator, amount\n\nclass MathFuncNode(ASTNode):\n    \"\"\"Set X to the sqrt/abs/floor/ceil/power of Y [and Z].\"\"\"\n    def __init__(self, target, func, operand, operand2=None):\n        self.target   = target    # variable to store result\n        self.func     = func      # 'sqrt','abs','floor','ceil','pow','max','min','log','exp'\n        self.operand  = operand   # primary operand\n        self.operand2 = operand2  # secondary (for pow/max/min)\n\nclass IncrDecrNode(ASTNode):\n    \"\"\"Increment / Decrement X.\"\"\"\n    def __init__(self, var_name, op):\n        self.var_name, self.op = var_name, op  # op = '++' or '--'\n\nclass ModuloNode(ASTNode):\n    \"\"\"Find the remainder of X divided by Y and store in Z.\"\"\"\n    def __init__(self, dividend, divisor, target):\n        self.dividend, self.divisor, self.target = dividend, divisor, target\n\nclass RandomNode(ASTNode):\n    \"\"\"Generate a random number between A and B and store in X.\"\"\"\n    def __init__(self, low, high, target):\n        self.low, self.high, self.target = low, high, target\n\nclass InputNode(ASTNode):\n    \"\"\"Ask the user to enter a value for X (with optional prompt).\"\"\"\n    def __init__(self, var_name, prompt=\"\"):\n        self.var_name, self.prompt = var_name, prompt\n\nclass InputStringNode(ASTNode):\n    \"\"\"Ask the user for text named X (with optional prompt).\"\"\"\n    def __init__(self, var_name, prompt=\"\"):\n        self.var_name, self.prompt = var_name, prompt\n\nclass PrintNode(ASTNode):\n    def __init__(self, var_name): self.var_name = var_name\n\nclass DisplayTextNode(ASTNode):\n    \"\"\"Display \"some text\" or display multiple variables.\"\"\"\n    def __init__(self, text): self.text = text\n\nclass DisplayVarNode(ASTNode):\n    \"\"\"Display the value of X and Y and Z...\"\"\"\n    def __init__(self, vars_list): self.vars_list = vars_list\n\nclass LoopNode(ASTNode):\n    def __init__(self): self.body = []\n\nclass ForLoopNode(ASTNode):\n    \"\"\"Repeat X times: ...\"\"\"\n    def __init__(self, count, body):\n        self.count, self.body = count, body\n\nclass WhileNode(ASTNode):\n    \"\"\"Keep running while X is less than Y: ...\"\"\"\n    def __init__(self, condition, body):\n        self.condition, self.body = condition, body\n\nclass IfNode(ASTNode):\n    def __init__(self, condition, true_body, false_body):\n        self.condition, self.true_body, self.false_body = condition, true_body, false_body\n\nclass OverrideBlockNode(ASTNode):\n    def __init__(self, code): self.code = code\n\nclass CommentNode(ASTNode):\n    def __init__(self, text): self.text = text\n\nclass PrintLineNode(ASTNode):\n    \"\"\"Print an empty blank separator line.\"\"\"\n    pass\n\nclass AssignNode(ASTNode):\n    \"\"\"Set X to Y (direct assignment).\"\"\"\n    def __init__(self, var_name, value):\n        self.var_name, self.value = var_name, value\n\nclass SwapNode(ASTNode):\n    \"\"\"Swap the values of X and Y.\"\"\"\n    def __init__(self, a, b): self.a, self.b = a, b\n\n# ═══════════════════════════════════════════════════════════════\n#  SELF-HEALING ENGINE\n# ═══════════════════════════════════════════════════════════════\n\nclass ErrorHealer:\n    @staticmethod\n    def heal(token):\n        R=\"\\033[0m\"; Y=\"\\033[93m\"; C=\"\\033[96m\"; G=\"\\033[90m\"; W=\"\\033[97m\"; B=\"\\033[1m\"\n        print(f\"\\n  {Y}⚠{R}  {B}{W}Self-Healing Engine  ·  Syntax Anomaly Detected{R}\")\n        print(f\"  {G}──────────────────────────────────────────────────────────────────{R}\")\n        print(f\"  {G}Line {token.line:<4}{R}  {Y}{token.value}{R}\")\n        print(f\"\\n  {C}Quick Reference:{R}\")\n        print(f\"  {G}·{R}  Variables  : Create a [integer/float] named X and set it to Y.\")\n        print(f\"  {G}·{R}  Strings    : Create a string named X and set it to \\\"text\\\".\")\n        print(f\"  {G}·{R}  Boolean    : Create a boolean named X and set it to true.\")\n        print(f\"  {G}·{R}  Input      : Ask the user to enter a value for X.\")\n        print(f\"  {G}·{R}  Input text : Ask the user for text named X.\")\n        print(f\"  {G}·{R}  Math       : Add/Subtract/Multiply/Divide X by Y.\")\n        print(f\"  {G}·{R}  Math funcs : Set X to the sqrt/abs/floor/ceil of Y.\")\n        print(f\"  {G}·{R}  Power      : Raise X to the power of Y.\")\n        print(f\"  {G}·{R}  Random     : Generate a random number between A and B and store in X.\")\n        print(f\"  {G}·{R}  Increment  : Increment X.  /  Decrement X.\")\n        print(f\"  {G}·{R}  Modulo     : Find the remainder of X divided by Y and store in Z.\")\n        print(f\"  {G}·{R}  Assign     : Set X to Y.\")\n        print(f\"  {G}·{R}  Swap       : Swap the values of X and Y.\")\n        print(f\"  {G}·{R}  Display    : Display \\\"Hello World\\\".  /  Display the value of X.\")\n        print(f\"  {G}·{R}  Log        : Log the value of X.\")\n        print(f\"  {G}·{R}  Loop       : Begin the main simulation loop.  ...  Halt the simulation.\")\n        print(f\"  {G}·{R}  Repeat     : Repeat 10 times: ... Done.\")\n        print(f\"  {G}·{R}  Condition  : If the X is greater than Y, then: ... Otherwise: ...\")\n        print(f\"  {G}──────────────────────────────────────────────────────────────────{R}\\n\")\n\n# ═══════════════════════════════════════════════════════════════\n#  MULTIVERSE PARSER — Self-Healing AST Engine\n# ═══════════════════════════════════════════════════════════════\n\nclass MultiverseParser:\n    def __init__(self, tokens):\n        self.tokens  = tokens\n        self.current = 0\n\n    def peek(self):\n        if self.current < len(self.tokens):\n            return self.tokens[self.current]\n        return self.tokens[-1]\n\n    def advance(self):\n        token = self.peek()\n        self.current += 1\n        return token\n\n    def parse(self):\n        program = ProgramNode()\n        while self.peek().type != TokenType.EOF:\n            stmt = self.parse_statement()\n            if stmt:\n                program.statements.append(stmt)\n        return program\n\n    # ── helpers ───────────────────────────────────────────────────────────\n    def _peek_contains(self, *keywords):\n        v = self.peek().value.lower()\n        return any(k in v for k in keywords)\n\n    def _collect_body_until(self, *stop_phrases):\n        body = []\n        while self.peek().type != TokenType.EOF:\n            v = self.peek().value.lower()\n            if any(p in v for p in stop_phrases):\n                break\n            if self.peek().type == TokenType.OVERRIDE_BLOCK:\n                break\n            stmt = self.parse_statement()\n            if stmt:\n                body.append(stmt)\n        return body\n\n    # ── main dispatcher ───────────────────────────────────────────────────\n    def parse_statement(self):\n        token   = self.advance()\n\n        if token.type == TokenType.OVERRIDE_BLOCK:\n            return OverrideBlockNode(token.value)\n\n        text  = token.value.lower()\n        orig  = token.value\n\n        # ── Sovereign / Engine ────────────────────────────────────────────\n        if \"initialize the cloaked zero-knowledge matrix\" in text:\n            return InitSovereignLayerNode()\n        if \"initialize high performance gaming viewport\" in text:\n            return InitViewportNode()\n        if \"sync the current game state to google cloud storage\" in text:\n            return SyncCloudNode()\n\n        # ── Render ────────────────────────────────────────────────────────\n        m = re.search(r'render a 3d matrix.*?at coordinates ([\\d.-]+),\\s*([\\d.-]+),\\s*([\\d.-]+)', text)\n        if m:\n            return RenderMatrixNode(m.group(1), m.group(2), m.group(3))\n\n        # ── Boolean Declaration ───────────────────────────────────────────\n        m = re.search(r'create a boolean named (\\w+) and set it to (true|false)', orig, re.IGNORECASE)\n        if m:\n            val = \"1\" if m.group(2).lower() == \"true\" else \"0\"\n            return BoolDeclarationNode(m.group(1), val)\n\n        # ── String Declaration ────────────────────────────────────────────\n        m = re.search(r'create a string named (\\w+) and set it to [\"\\']?(.*?)[\"\\']?\\s*\$', orig, re.IGNORECASE)\n        if m:\n            return StringDeclarationNode(m.group(1), m.group(2).strip('\"\\''))\n\n        # ── Numeric Variable Declaration ──────────────────────────────────\n        m = re.search(r'create a(?:.*?)(integer|floating point variable) named (\\w+) and set it to ([\\d.-]+)', orig, re.IGNORECASE)\n        if m:\n            return VariableDeclarationNode(m.group(2), m.group(1).lower(), m.group(3))\n\n        # ── Direct Assignment ─────────────────────────────────────────────\n        m = re.search(r'^set (\\w+) to ([\\d.\\w\"\\'+-]+)\\s*\$', orig, re.IGNORECASE)\n        if m:\n            return AssignNode(m.group(1), m.group(2))\n\n        # ── Swap ─────────────────────────────────────────────────────────\n        m = re.search(r'swap the values of (\\w+) and (\\w+)', orig, re.IGNORECASE)\n        if m:\n            return SwapNode(m.group(1), m.group(2))\n\n        # ── User Input (numeric) ──────────────────────────────────────────\n        m = re.search(r'ask the user to enter a value for (\\w+)', orig, re.IGNORECASE)\n        if m:\n            prompt_m = re.search(r'with prompt [\"\\'](.+?)[\"\\']', orig, re.IGNORECASE)\n            prompt = prompt_m.group(1) if prompt_m else f\"Enter value for {m.group(1)}\"\n            return InputNode(m.group(1), prompt)\n\n        m = re.search(r'ask the user for (?:a )?(?:number|value|integer|float) (?:named |called )?(\\w+)', orig, re.IGNORECASE)\n        if m:\n            return InputNode(m.group(1), f\"Enter {m.group(1)}\")\n\n        # ── User Input (string/text) ──────────────────────────────────────\n        m = re.search(r'ask the user for text (?:named |called )?(\\w+)', orig, re.IGNORECASE)\n        if m:\n            return InputStringNode(m.group(1), f\"Enter {m.group(1)}\")\n\n        m = re.search(r'ask the user to enter text for (\\w+)', orig, re.IGNORECASE)\n        if m:\n            prompt_m = re.search(r'with prompt [\"\\'](.+?)[\"\\']', orig, re.IGNORECASE)\n            prompt = prompt_m.group(1) if prompt_m else f\"Enter text for {m.group(1)}\"\n            return InputStringNode(m.group(1), prompt)\n\n        # ── Math Functions ────────────────────────────────────────────────\n        m = re.search(r'set (\\w+) to the square root of ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'sqrt', m.group(2))\n\n        m = re.search(r'set (\\w+) to the absolute value of ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'abs', m.group(2))\n\n        m = re.search(r'set (\\w+) to the floor of ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'floor', m.group(2))\n\n        m = re.search(r'set (\\w+) to the ceiling of ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'ceil', m.group(2))\n\n        m = re.search(r'set (\\w+) to the natural log of ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'log', m.group(2))\n\n        m = re.search(r'set (\\w+) to e to the power of ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'exp', m.group(2))\n\n        m = re.search(r'set (\\w+) to the maximum of ([\\w.]+) and ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'max', m.group(2), m.group(3))\n\n        m = re.search(r'set (\\w+) to the minimum of ([\\w.]+) and ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'min', m.group(2), m.group(3))\n\n        # Raise X to the power of Y  (sets X = X^Y)\n        m = re.search(r'raise (\\w+) to the power of ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'pow_self', m.group(1), m.group(2))\n\n        # Set X to Y to the power of Z\n        m = re.search(r'set (\\w+) to ([\\w.]+) to the power of ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathFuncNode(m.group(1), 'pow', m.group(2), m.group(3))\n\n        # ── Modulo ────────────────────────────────────────────────────────\n        m = re.search(r'find the remainder of (\\w+) divided by ([\\w.]+) and store in (\\w+)', orig, re.IGNORECASE)\n        if m: return ModuloNode(m.group(1), m.group(2), m.group(3))\n\n        m = re.search(r'set (\\w+) to (\\w+) modulo ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return ModuloNode(m.group(2), m.group(3), m.group(1))\n\n        # ── Random ────────────────────────────────────────────────────────\n        m = re.search(r'generate a random (?:number|integer) between ([\\w.]+) and ([\\w.]+) and store in (\\w+)', orig, re.IGNORECASE)\n        if m: return RandomNode(m.group(1), m.group(2), m.group(3))\n\n        m = re.search(r'set (\\w+) to a random number between ([\\w.]+) and ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return RandomNode(m.group(2), m.group(3), m.group(1))\n\n        # ── Increment / Decrement ─────────────────────────────────────────\n        m = re.search(r'increment (\\w+)', orig, re.IGNORECASE)\n        if m: return IncrDecrNode(m.group(1), '++')\n\n        m = re.search(r'decrement (\\w+)', orig, re.IGNORECASE)\n        if m: return IncrDecrNode(m.group(1), '--')\n\n        # ── Standard Math Operations ──────────────────────────────────────\n        m = re.search(r'add ([\\w.]+) to (\\w+)', orig, re.IGNORECASE)\n        if m: return MathOpNode(m.group(2), '+', m.group(1))\n\n        m = re.search(r'increase (\\w+) by ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathOpNode(m.group(1), '+', m.group(2))\n\n        m = re.search(r'subtract ([\\w.]+) from (\\w+)', orig, re.IGNORECASE)\n        if m: return MathOpNode(m.group(2), '-', m.group(1))\n\n        m = re.search(r'decrease (\\w+) by ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathOpNode(m.group(1), '-', m.group(2))\n\n        m = re.search(r'multiply (\\w+) by ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathOpNode(m.group(1), '*', m.group(2))\n\n        m = re.search(r'divide (\\w+) by ([\\w.]+)', orig, re.IGNORECASE)\n        if m: return MathOpNode(m.group(1), '/', m.group(2))\n\n        # ── Display / Output ──────────────────────────────────────────────\n        m = re.search(r'display the values? of (.+)', orig, re.IGNORECASE)\n        if m:\n            parts = [v.strip() for v in re.split(r'\\s+and\\s+|\\s*,\\s*', m.group(1))]\n            return DisplayVarNode(parts)\n\n        m = re.search(r'display [\"\\'](.+?)[\"\\']', orig, re.IGNORECASE)\n        if m: return DisplayTextNode(m.group(1))\n\n        m = re.search(r'^display (.+)\$', orig, re.IGNORECASE)\n        if m:\n            inner = m.group(1).strip().strip('\"\\'')\n            return DisplayTextNode(inner)\n\n        m = re.search(r'log the value of (\\w+)', orig, re.IGNORECASE)\n        if m: return PrintNode(m.group(1))\n\n        m = re.search(r'print a blank line', orig, re.IGNORECASE)\n        if m: return PrintLineNode()\n\n        # ── Loops ─────────────────────────────────────────────────────────\n        if \"begin the main simulation loop\" in text:\n            loop_node = LoopNode()\n            loop_node.body = self._collect_body_until(\n                \"sync the current game state\", \"halt the simulation\"\n            )\n            return loop_node\n\n        m = re.search(r'repeat ([\\w]+) times?', orig, re.IGNORECASE)\n        if m:\n            body = self._collect_body_until(\"done\", \"end repeat\", \"sync the current game state\")\n            if self._peek_contains(\"done\", \"end repeat\"):\n                self.advance()\n            return ForLoopNode(m.group(1), body)\n\n        m = re.search(r'keep running while (.+)', orig, re.IGNORECASE)\n        if m:\n            raw_cond = m.group(1).strip()\n            cond = self._build_condition(raw_cond)\n            body = self._collect_body_until(\"stop the loop\", \"end while\", \"sync the current game state\")\n            if self._peek_contains(\"stop the loop\", \"end while\"):\n                self.advance()\n            return WhileNode(cond, body)\n\n        # ── Conditionals ──────────────────────────────────────────────────\n        full_m = re.search(\n            r'if (?:the )?(.*?) (drops below|is less than|is greater than|equals|is not|is) (.+?),? then',\n            orig, re.IGNORECASE)\n        \n        if full_m:\n            var1 = full_m.group(1).strip()\n            op_raw = full_m.group(2).strip().lower()\n            var2 = full_m.group(3).strip()\n            \n            op_map = {\"drops below\": \"<\", \"is less than\": \"<\",\n                      \"is greater than\": \">\", \"equals\": \"==\",\n                      \"is not\": \"!=\", \"is\": \"==\"}\n                      \n            if var2.lower() == \"zero\": var2 = \"0\"\n            if var2.lower() == \"true\": var2 = \"1\"\n            if var2.lower() == \"false\": var2 = \"0\"\n            \n            condition = f\"{var1} {op_map.get(op_raw, '==')} {var2}\"\n            \n            true_body = self._collect_body_until(\"otherwise\", \"end if\", \"sync the current game state\")\n            false_body = []\n            \n            if self._peek_contains(\"otherwise\"):\n                self.advance()\n                false_body = self._collect_body_until(\"end if\", \"sync the current game state\")\n                \n            if self._peek_contains(\"end if\"):\n                self.advance()\n                \n            return IfNode(condition, true_body, false_body)\n\n        # ── Halt / Continue ───────────────────────────────────────────────\n        if \"trigger the game over sequence\" in text:\n            return PrintNode('\"GAME OVER SEQUENCE TRIGGERED\"')\n        if \"halt the simulation\" in text:\n            return HaltNode()\n        if \"keep the simulation running\" in text or text.strip() in (\"continue\", \"otherwise\"):\n            return ContinueNode()\n\n        # ── Fallthrough ───────────────────────────────────────────────────\n        ErrorHealer.heal(token)\n        return None\n\n    def _build_condition(self, raw):\n        \"\"\"Convert English condition to C expression.\"\"\"\n        op_map = {\n            \"is less than\": \"<\", \"is greater than\": \">\",\n            \"equals\": \"==\", \"is not equal to\": \"!=\",\n            \"is\": \"==\", \"drops below\": \"<\",\n        }\n        for eng, sym in op_map.items():\n            m = re.search(rf'(.+?)\\s+{re.escape(eng)}\\s+(.+)', raw, re.IGNORECASE)\n            if m:\n                return f\"{m.group(1).strip()} {sym} {m.group(2).strip()}\"\n        return raw  # fallback: pass raw as C expression\n\n\n\n\n\nEOF_NATCOM_BOOTSTRAP");
    system("cat << \'EOF_NATCOM_BOOTSTRAP\' > src/codegen.py\nimport os\nimport subprocess\nfrom src.parser import *\n\n# ── ANSI Color macros emitted into every compiled binary ─────────────────────\n_C_COLORS = '''\\\n#define RESET   \"\\\\033[0m\"\n#define BOLD    \"\\\\033[1m\"\n#define CYAN    \"\\\\033[96m\"\n#define GREEN   \"\\\\033[92m\"\n#define YELLOW  \"\\\\033[93m\"\n#define RED     \"\\\\033[91m\"\n#define PURPLE  \"\\\\033[95m\"\n#define WHITE   \"\\\\033[97m\"\n#define GRAY    \"\\\\033[90m\"\n'''\n\n_C_TIMING = '''\\\n#include <time.h>\nstatic struct timespec _nc_t0;\nstatic void _nc_start_timer(void){clock_gettime(CLOCK_MONOTONIC,&_nc_t0);}\nstatic double _nc_elapsed_ms(void){\n    struct timespec t1; clock_gettime(CLOCK_MONOTONIC,&t1);\n    return (t1.tv_sec-_nc_t0.tv_sec)*1000.0+(t1.tv_nsec-_nc_t0.tv_nsec)/1e6;\n}\n'''\n\n_C_HELPERS = '''\\\nstatic void nc_value_f(const char*name,double v){\n    printf(\"  \" CYAN \"◆\" RESET \"  \" WHITE \"%-24s\" RESET \" \" BOLD CYAN \"%g\" RESET \"\\\\n\",name,v);}\nstatic void nc_value_s(const char*name,const char*v){\n    printf(\"  \" CYAN \"◆\" RESET \"  \" WHITE \"%-24s\" RESET \" \" BOLD WHITE \"%s\" RESET \"\\\\n\",name,v);}\nstatic void nc_value_b(const char*name,int v){\n    printf(\"  \" CYAN \"◆\" RESET \"  \" WHITE \"%-24s\" RESET \" \" BOLD \"%s\" RESET \"\\\\n\",name,v?\"true\":\"false\");}\nstatic void nc_log(const char*label,const char*fmt,...){\n    va_list a; printf(\"  \" GREEN \"▶\" RESET \"  \" BOLD WHITE \"%-22s\" RESET \" \",label);\n    va_start(a,fmt);vprintf(fmt,a);va_end(a);printf(\"\\\\n\");}\nstatic void nc_info(const char*m){printf(\"  \" GRAY \"·\" RESET \"  \" GRAY \"%s\" RESET \"\\\\n\",m);}\nstatic void nc_section(const char*l){printf(\"\\\\n  \" PURPLE BOLD \"%s\" RESET \"\\\\n\",l);}\nstatic void nc_hr(void){\n    printf(GRAY \"  ──────────────────────────────────────────────────────────────────────\" RESET \"\\\\n\");}\nstatic void nc_banner(const char*p){\n    printf(\"\\\\n\");\n    printf(CYAN \"  ══════════════════════════════════════════════════════════════════════\" RESET \"\\\\n\");\n    printf(CYAN BOLD \"  NATCOM RUNTIME  ·  %s\" RESET \"\\\\n\",p);\n    printf(GRAY \"  Natural Communication Language  ·  Native Binary  ·  -O3 Optimized\" RESET \"\\\\n\");\n    printf(CYAN \"  ══════════════════════════════════════════════════════════════════════\" RESET \"\\\\n\\\\n\");}\nstatic void nc_footer(double ms){\n    printf(\"\\\\n\"); nc_hr();\n    printf(\"  \" GREEN \"✔\" RESET \"  \" BOLD WHITE \"Execution complete\" RESET \"  \" GRAY \"(%.0f ms)\" RESET \"\\\\n\",ms);\n    printf(CYAN \"  ══════════════════════════════════════════════════════════════════════\" RESET \"\\\\n\\\\n\");}\nstatic void nc_display(const char*msg){printf(\"  \" WHITE \"  %s\" RESET \"\\\\n\",msg);}\nstatic void nc_input_prompt(const char*msg){\n    printf(\"  \" YELLOW \"▷\" RESET \"  \" BOLD WHITE \"%s\" RESET \": \",msg);}\n'''\n\n_C_SOVEREIGN = '''\\\nstatic void init_sovereign_matrix(void){\n    nc_section(\"SOVEREIGN LAYER\");\n    nc_log(\"ZKP Audit\",\"Cloaked zero-knowledge proof hooks initialized.\");\n    nc_info(\"Cryptographic traceability: ENABLED\");}\nstatic void init_viewport(void){\n    nc_section(\"GAMING ENGINE\");\n    nc_log(\"Viewport\",\"High-performance 3D viewport online.\");\n    nc_log(\"Physics\",\"Gravity engine initialized  (g = 9.81 m/s\\\\xc2\\\\xb2)\");}\nstatic void render_matrix(float x,float y,float z){\n    nc_log(\"Render\",\"3D matrix positioned at (%.2f, %.2f, %.2f)\",x,y,z);}\nstatic void sync_cloud_ram(void){\n    nc_section(\"CLOUD SYNC\");\n    nc_log(\"GCP Sync\",\"State serialized to Google Cloud Storage.\");\n    nc_info(\"Offline fallback: ACTIVE\");}\nstatic void flush_render_pipeline(void){nc_log(\"Pipeline\",\"Render pipeline flushed.\");}\n'''\n\n\nclass SystemsCodeGen:\n    def __init__(self, ast, output_bin=\"program\", target=\"c\"):\n        self.ast        = ast\n        self.output_bin = output_bin\n        self.target     = target.lower()\n        self.out_code   = []\n        self._needs_math  = False\n        self._needs_rand  = False\n        self._needs_str   = False\n        self._str_vars    = set()   # string variable names\n        self._bool_vars   = set()   # boolean variable names\n        self._tmp_counter = 0\n\n    # ── public entry ────────────────────────────────────────────────────────\n    def generate(self):\n        # First pass: detect required includes\n        self._scan_needs(self.ast)\n        if self.target == \"js\":\n            self._generate_js()\n        else:\n            self._generate_c()\n\n    def _scan_needs(self, node):\n        if isinstance(node, ProgramNode):\n            for s in node.statements: self._scan_needs(s)\n        elif isinstance(node, (MathFuncNode,)):\n            self._needs_math = True\n        elif isinstance(node, RandomNode):\n            self._needs_rand = True\n        elif isinstance(node, (StringDeclarationNode, InputStringNode, DisplayTextNode)):\n            self._needs_str = True\n        elif isinstance(node, (LoopNode, ForLoopNode, WhileNode)):\n            for s in node.body: self._scan_needs(s)\n        elif isinstance(node, IfNode):\n            for s in node.true_body + node.false_body: self._scan_needs(s)\n\n    # ── JS Backend ──────────────────────────────────────────────────────────\n    def _generate_js(self):\n        self.out_code += [\n            \"// ============================================================\",\n            \"//  NATCOM STUDIO — JavaScript Bootstrap Matrix\",\n            \"//  Auto-generated by NATCOM Compiler v2.0\",\n            \"// ============================================================\",\n            \"\",\n            \"console.log('[NATCOM JS] Bootstrap matrix initialized.');\",\n            \"\",\n        ]\n        self.visit(self.ast)\n        js_path = self.output_bin if self.output_bin.endswith(\".js\") else self.output_bin + \".js\"\n        with open(js_path, \"w\") as f:\n            f.write(\"\\n\".join(self.out_code))\n\n    # ── C Backend ───────────────────────────────────────────────────────────\n    def _generate_c(self):\n        prog = os.path.basename(self.output_bin).upper()\n        code = self.out_code\n\n        # Includes\n        code += [\"#include <stdio.h>\", \"#include <stdlib.h>\",\n                 \"#include <stdarg.h>\", \"#include <stdbool.h>\",\n                 \"#include <string.h>\", \"\"]\n        if self._needs_math:\n            code.append(\"#include <math.h>\")\n        if self._needs_rand:\n            code.append(\"#include <time.h>\")\n        code.append(\"\")\n\n        # Macros & helpers\n        for ln in _C_COLORS.splitlines(): code.append(ln)\n        code.append(\"\")\n        for ln in _C_TIMING.splitlines(): code.append(ln)\n        code.append(\"\")\n        for ln in _C_HELPERS.splitlines(): code.append(ln)\n        code.append(\"\")\n        for ln in _C_SOVEREIGN.splitlines(): code.append(ln)\n        code.append(\"\")\n\n        # main()\n        code.append(\"int main(void) {\")\n        if self._needs_rand:\n            code.append(\"    srand((unsigned)time(NULL));\")\n        code.append(f'    nc_banner(\"{prog}\");')\n        code.append(\"    _nc_start_timer();\")\n        code.append('    nc_section(\"PROGRAM OUTPUT\");')\n\n        self.visit(self.ast)\n\n        code.append(\"    nc_footer(_nc_elapsed_ms());\")\n        code.append('    printf(\"  Press Enter to exit...\\\\n\");')\n        code.append(\"    getchar();\")\n        code.append(\"    return 0;\")\n        code.append(\"}\")\n\n        c_path = f\"{self.output_bin}.c\"\n        with open(c_path, \"w\") as f:\n            f.write(\"\\n\".join(code))\n\n        libs = [\"-lm\"] if self._needs_math else []\n        res = subprocess.run(\n            [\"gcc\", \"-O3\", \"-Wno-unused-function\", \"-Wno-unused-variable\",\n             \"-fstack-protector-strong\", c_path, \"-o\", self.output_bin] + libs,\n            capture_output=True, text=True\n        )\n        if res.returncode != 0:\n            print(f\"\\033[91m[!] GCC Error:\\033[0m\\n{res.stderr}\")\n\n    # ── Visitor ─────────────────────────────────────────────────────────────\n    def visit(self, node, indent=\"    \"):\n        js = self.target == \"js\"\n        if js and indent == \"    \":\n            indent = \"\"\n\n        c = self.out_code  # alias\n\n        if isinstance(node, ProgramNode):\n            for stmt in node.statements:\n                self.visit(stmt, indent)\n\n        # ── Sovereign / Engine ──────────────────────────────────────────────\n        elif isinstance(node, InitSovereignLayerNode):\n            if js: c.append(f\"{indent}console.log('[SOVEREIGN] ZKP audit hooks initialized.');\")\n            else:  c.append(f\"{indent}init_sovereign_matrix();\")\n\n        elif isinstance(node, InitViewportNode):\n            if js: c.append(f\"{indent}console.log('[ENGINE] Gaming viewport initialized.');\")\n            else:  c.append(f\"{indent}init_viewport();\")\n\n        elif isinstance(node, SyncCloudNode):\n            if js: c.append(f\"{indent}console.log('[GCP] State synced.');\")\n            else:  c.append(f\"{indent}sync_cloud_ram();\")\n\n        elif isinstance(node, RenderMatrixNode):\n            if js: c.append(f\"{indent}console.log('[RENDER] Matrix at ({node.x},{node.y},{node.z})');\")\n            else:  c.append(f\"{indent}render_matrix({node.x},{node.y},{node.z});\")\n\n        # ── Variable Declarations ───────────────────────────────────────────\n        elif isinstance(node, VariableDeclarationNode):\n            if js:\n                c.append(f\"{indent}let {node.name} = {node.value};\")\n            else:\n                t = \"int\" if \"integer\" in node.var_type else \"float\"\n                c.append(f\"{indent}{t} {node.name} = {node.value};\")\n\n        elif isinstance(node, StringDeclarationNode):\n            self._str_vars.add(node.name)\n            if js:\n                c.append(f'{indent}let {node.name} = \"{node.value}\";')\n            else:\n                safe = node.value.replace('\"', '\\\\\"')\n                c.append(f'{indent}char {node.name}[512] = \"{safe}\";')\n\n        elif isinstance(node, BoolDeclarationNode):\n            self._bool_vars.add(node.name)\n            if js:\n                val = \"true\" if node.value == \"1\" else \"false\"\n                c.append(f\"{indent}let {node.name} = {val};\")\n            else:\n                c.append(f\"{indent}int {node.name} = {node.value};\")\n\n        # ── Assignment ──────────────────────────────────────────────────────\n        elif isinstance(node, AssignNode):\n            if js: c.append(f\"{indent}{node.var_name} = {node.value};\")\n            else:  c.append(f\"{indent}{node.var_name} = {node.value};\")\n\n        # ── Swap ────────────────────────────────────────────────────────────\n        elif isinstance(node, SwapNode):\n            if js:\n                c.append(f\"{indent}[{node.a}, {node.b}] = [{node.b}, {node.a}];\")\n            else:\n                tmp = f\"_nc_tmp_{self._tmp_counter}\"; self._tmp_counter += 1\n                c.append(f\"{indent}{{ float {tmp} = {node.a}; {node.a} = {node.b}; {node.b} = {tmp}; }}\")\n\n        # ── Math Operations ─────────────────────────────────────────────────\n        elif isinstance(node, MathOpNode):\n            c.append(f\"{indent}{node.var_name} = {node.var_name} {node.operator} {node.amount};\")\n\n        elif isinstance(node, IncrDecrNode):\n            c.append(f\"{indent}{node.var_name}{node.op};\")\n\n        elif isinstance(node, MathFuncNode):\n            self._needs_math = True\n            f_ = node.func\n            t, op, op2 = node.target, node.operand, node.operand2\n            if js:\n                js_map = {\n                    'sqrt': f\"Math.sqrt({op})\", 'abs': f\"Math.abs({op})\",\n                    'floor': f\"Math.floor({op})\", 'ceil': f\"Math.ceil({op})\",\n                    'log': f\"Math.log({op})\", 'exp': f\"Math.exp({op})\",\n                    'max': f\"Math.max({op},{op2})\", 'min': f\"Math.min({op},{op2})\",\n                    'pow': f\"Math.pow({op},{op2})\", 'pow_self': f\"Math.pow({op},{op2})\",\n                }\n                c.append(f\"{indent}{t} = {js_map.get(f_, op)};\")\n            else:\n                c_map = {\n                    'sqrt': f\"sqrt((double)({op}))\",\n                    'abs':  f\"fabs((double)({op}))\",\n                    'floor':f\"floor((double)({op}))\",\n                    'ceil': f\"ceil((double)({op}))\",\n                    'log':  f\"log((double)({op}))\",\n                    'exp':  f\"exp((double)({op}))\",\n                    'max':  f\"(({op})>({op2})?({op}):({op2}))\",\n                    'min':  f\"(({op})<({op2})?({op}):({op2}))\",\n                    'pow':  f\"pow((double)({op}),(double)({op2}))\",\n                    'pow_self': f\"pow((double)({op}),(double)({op2}))\",\n                }\n                c.append(f\"{indent}{t} = {c_map.get(f_, op)};\")\n\n        elif isinstance(node, ModuloNode):\n            if js: c.append(f\"{indent}{node.target} = {node.dividend} % {node.divisor};\")\n            else:  c.append(f\"{indent}{node.target} = (int)({node.dividend}) % (int)({node.divisor});\")\n\n        elif isinstance(node, RandomNode):\n            self._needs_rand = True\n            if js:\n                c.append(f\"{indent}{node.target} = Math.floor(Math.random() * ({node.high} - {node.low} + 1)) + {node.low};\")\n            else:\n                c.append(f\"{indent}{node.target} = (rand() % ((int)({node.high}) - (int)({node.low}) + 1)) + (int)({node.low});\")\n\n        # ── User Input ──────────────────────────────────────────────────────\n        elif isinstance(node, InputNode):\n            safe_p = node.prompt.replace('\"', '\\\\\"')\n            if js:\n                c.append(f\"{indent}// [INPUT] {node.var_name} — user input required (use prompt() in browser)\")\n                c.append(f\"{indent}{node.var_name} = parseFloat(prompt('{safe_p}') || '0');\")\n            else:\n                c.append(f'{indent}nc_input_prompt(\"{safe_p}\");')\n                c.append(f\"{indent}scanf(\\\"%lf\\\", &{node.var_name});\")\n                c.append(f'{indent}nc_log(\"Input received\", \"%g\", (double){node.var_name});')\n\n        elif isinstance(node, InputStringNode):\n            safe_p = node.prompt.replace('\"', '\\\\\"')\n            if js:\n                c.append(f\"{indent}{node.var_name} = prompt('{safe_p}') || '';\")\n            else:\n                c.append(f'{indent}nc_input_prompt(\"{safe_p}\");')\n                c.append(f\"{indent}fgets({node.var_name}, sizeof({node.var_name}), stdin);\")\n                c.append(f\"{indent}{node.var_name}[strcspn({node.var_name}, \\\"\\\\n\\\")] = 0;\")\n                c.append(f'{indent}nc_log(\"Text received\", \"%s\", {node.var_name});')\n\n        # ── Print / Display ─────────────────────────────────────────────────\n        elif isinstance(node, PrintNode):\n            vn = node.var_name\n            if js:\n                c.append(f\"{indent}console.log('  ◆  {vn} =', {vn});\")\n            else:\n                if vn.startswith('\"'):\n                    # Literal string constant\n                    c.append(f'{indent}nc_log(\"Output\", \"%s\", {vn});')\n                elif vn in self._str_vars:\n                    c.append(f'{indent}nc_value_s(\"{vn}\", {vn});')\n                elif vn in self._bool_vars:\n                    c.append(f'{indent}nc_value_b(\"{vn}\", {vn});')\n                else:\n                    # Default: treat as numeric float\n                    c.append(f'{indent}nc_value_f(\"{vn}\", (double){vn});')\n\n\n        elif isinstance(node, DisplayTextNode):\n            safe = node.text.replace('\"', '\\\\\"')\n            if js: c.append(f'{indent}console.log(\"  {safe}\");')\n            else:  c.append(f'{indent}nc_display(\"{safe}\");')\n\n        elif isinstance(node, DisplayVarNode):\n            for vn in node.vars_list:\n                if js: c.append(f'{indent}console.log(\"  ◆  {vn} =\", {vn});')\n                elif vn in self._str_vars:  c.append(f'{indent}nc_value_s(\"{vn}\", {vn});')\n                elif vn in self._bool_vars: c.append(f'{indent}nc_value_b(\"{vn}\", {vn});')\n                else: c.append(f'{indent}nc_value_f(\"{vn}\", (double){vn});')\n\n\n        elif isinstance(node, PrintLineNode):\n            if js: c.append(f'{indent}console.log(\"\");')\n            else:  c.append(f'{indent}printf(\"\\\\n\");')\n\n        # ── Loops ───────────────────────────────────────────────────────────\n        elif isinstance(node, LoopNode):\n            c.append(f\"{indent}while(1) {{\")\n            for s in node.body: self.visit(s, indent + \"    \")\n            c.append(f\"{indent}}}\")\n\n        elif isinstance(node, ForLoopNode):\n            c.append(f\"{indent}for(int _i = 0; _i < {node.count}; _i++) {{\")\n            for s in node.body: self.visit(s, indent + \"    \")\n            c.append(f\"{indent}}}\")\n\n        elif isinstance(node, WhileNode):\n            c.append(f\"{indent}while({node.condition}) {{\")\n            for s in node.body: self.visit(s, indent + \"    \")\n            c.append(f\"{indent}}}\")\n\n        # ── Conditionals ────────────────────────────────────────────────────\n        elif isinstance(node, IfNode):\n            c.append(f\"{indent}if ({node.condition}) {{\")\n            for s in node.true_body:  self.visit(s, indent + \"    \")\n            if node.false_body:\n                c.append(f\"{indent}}} else {{\")\n                for s in node.false_body: self.visit(s, indent + \"    \")\n            c.append(f\"{indent}}}\")\n\n        elif isinstance(node, HaltNode):\n            if js: c.append(f\"{indent}console.log('[ENGINE] Simulation halted.');\")\n            else:  c.append(f'{indent}nc_info(\"Simulation halted gracefully.\");')\n            c.append(f\"{indent}break;\")\n\n        elif isinstance(node, ContinueNode):\n            c.append(f\"{indent}/* continue */\")\n\n        # ── Override ────────────────────────────────────────────────────────\n        elif isinstance(node, OverrideBlockNode):\n            c.append(f\"{indent}/* ── SYSTEM OVERRIDE ── */\")\n            for ln in node.code.split('\\n'):\n                c.append(f\"{indent}{ln}\")\n\n\n\n\n\nEOF_NATCOM_BOOTSTRAP");
    system("cat << \'EOF_NATCOM_BOOTSTRAP\' > server.py\nimport os\nimport json\nimport subprocess\nfrom http.server import HTTPServer, SimpleHTTPRequestHandler\n\nPORT = 8080\nUI_DIR = os.path.join(os.path.dirname(__file__), \"ui\")\nCOMPILER_SCRIPT = os.path.join(os.path.dirname(__file__), \"natcom\")\n\nclass NatcomRequestHandler(SimpleHTTPRequestHandler):\n    def __init__(self, *args, **kwargs):\n        super().__init__(*args, directory=UI_DIR, **kwargs)\n\n    def do_POST(self):\n        if self.path == \"/compile\":\n            content_length = int(self.headers['Content-Length'])\n            post_data = self.rfile.read(content_length)\n            data = json.loads(post_data.decode('utf-8'))\n            code = data.get(\"code\", \"\")\n            target = data.get(\"target\", \"c\")\n            user_stdin = data.get(\"stdin\", \"\")\n\n            # Save to temporary workspace\n            workspace_file = \"web_workspace.nc\"\n            output_bin = \"web_engine\"\n            \n            with open(workspace_file, \"w\") as f:\n                f.write(code)\n\n            # Build and Execute\n            build_cmd = [COMPILER_SCRIPT, \"build\", workspace_file, \"-o\", output_bin, \"--target\", target]\n            build_process = subprocess.run(build_cmd, capture_output=True, text=True)\n            \n            output = build_process.stdout + \"\\n\" + build_process.stderr\n\n            if build_process.returncode == 0:\n                # If build succeeds, run the binary. \n                # Provide the user_stdin and a newline to bypass the 'Press Enter to exit' pause.\n                run_input = user_stdin\n                if not run_input.endswith(\"\\n\"):\n                    run_input += \"\\n\"\n                    \n                try:\n                    run_process = subprocess.run([f\"./{output_bin}\"], input=run_input, capture_output=True, text=True, timeout=5)\n                    output += \"\\n\" + run_process.stdout + \"\\n\" + run_process.stderr\n                except subprocess.TimeoutExpired:\n                    output += \"\\n[SYSTEM] Timeout: Execution exceeded 5 seconds. (Waiting for input?)\"\n            \n            self.send_response(200)\n            self.send_header('Content-type', 'application/json')\n            self.end_headers()\n            response = {\"output\": output}\n            self.wfile.write(json.dumps(response).encode('utf-8'))\n        else:\n            self.send_error(404)\n\nif __name__ == \"__main__\":\n    if not os.path.exists(UI_DIR):\n        os.makedirs(UI_DIR)\n        \n    print(f\"[*] Starting NATCOM Studio Backend on http://localhost:{PORT}\")\n    print(f\"[*] Serving UI from {UI_DIR}\")\n    server = HTTPServer(('', PORT), NatcomRequestHandler)\n    try:\n        server.serve_forever()\n    except KeyboardInterrupt:\n        pass\n    server.server_close()\n    print(\"[*] Server stopped.\")\n\n\n\n\nEOF_NATCOM_BOOTSTRAP");
    system("cat << \'EOF_NATCOM_BOOTSTRAP\' > ui/index.html\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>NATCOM Studio — Sovereign IDE</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"style.css\">\n</head>\n<body>\n\n<!-- TITLE BAR -->\n<div class=\"titlebar\">\n    <div class=\"titlebar-left\">\n        <div class=\"traffic-lights\">\n            <span class=\"tl tl-red\"></span>\n            <span class=\"tl tl-yellow\"></span>\n            <span class=\"tl tl-green\"></span>\n        </div>\n        <div class=\"app-brand\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M12 2L2 7L12 12L22 7L12 2Z\" fill=\"#00ffcc\" opacity=\"0.9\"/>\n                <path d=\"M2 17L12 22L22 17\" stroke=\"#00ffcc\" stroke-width=\"1.5\" fill=\"none\"/>\n                <path d=\"M2 12L12 17L22 12\" stroke=\"#00ffcc\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.6\"/>\n            </svg>\n            <span class=\"brand-name\">NATCOM <span class=\"brand-studio\">Studio</span></span>\n            <span class=\"brand-version\">v2.0</span>\n        </div>\n    </div>\n    <div class=\"titlebar-center\">\n        <div class=\"breadcrumb\">\n            <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/></svg>\n            <span class=\"bc-root\">NATCOM</span>\n            <span class=\"bc-sep\">›</span>\n            <span class=\"bc-file\" id=\"breadcrumb-file\">main.nc</span>\n        </div>\n    </div>\n    <div class=\"titlebar-right\">\n        <div class=\"sovereign-status\">\n            <div class=\"pulse-dot\"></div>\n            <span>Sovereign Link Active</span>\n        </div>\n    </div>\n</div>\n\n<!-- MENU BAR -->\n<div class=\"menubar\">\n    <div class=\"menubar-left\">\n        <button class=\"menu-item\" onclick=\"newFile()\">File</button>\n        <button class=\"menu-item\">Edit</button>\n        <button class=\"menu-item\" onclick=\"runCode()\">Run</button>\n        <button class=\"menu-item\">View</button>\n        <button class=\"menu-item\" onclick=\"window.open('about.html','_blank')\">About Creator</button>\n    </div>\n    <div class=\"menubar-actions\">\n        <div class=\"error-badge\" id=\"errorBadge\" style=\"display:none\">\n            <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"#ff6b6b\"><path d=\"M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z\"/></svg>\n            <span id=\"errorCount\">0 errors</span>\n        </div>\n        <button class=\"run-btn\" onclick=\"runCode()\" id=\"runBtn\">\n            <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M5 3L19 12L5 21V3Z\"/></svg>\n            Run\n        </button>\n        <button class=\"build-btn\" onclick=\"buildCode()\" id=\"buildBtn\">\n            <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/></svg>\n            Build\n        </button>\n    </div>\n</div>\n\n<!-- MAIN LAYOUT -->\n<div class=\"ide-layout\">\n\n    <!-- ACTIVITY BAR -->\n    <div class=\"activity-bar\">\n        <button class=\"activity-btn active\" id=\"act-explorer\" onclick=\"switchActivity('explorer')\" title=\"Explorer (Ctrl+B)\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><path d=\"M3 9h18M9 21V9\"/></svg>\n        </button>\n        <button class=\"activity-btn\" id=\"act-examples\" onclick=\"switchActivity('examples')\" title=\"Examples\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/><path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/></svg>\n        </button>\n        <button class=\"activity-btn\" id=\"act-search\" onclick=\"switchActivity('search')\" title=\"Search\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.35-4.35\"/></svg>\n        </button>\n        <button class=\"activity-btn\" id=\"act-cheatsheet\" onclick=\"switchActivity('cheatsheet')\" title=\"Language Reference\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3\"/><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"/></svg>\n        </button>\n        <div class=\"activity-spacer\"></div>\n        <button class=\"activity-btn\" id=\"act-settings\" onclick=\"switchActivity('settings')\" title=\"Settings\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z\"/></svg>\n        </button>\n    </div>\n\n    <!-- SIDEBAR -->\n    <div class=\"sidebar\" id=\"sidebar\">\n\n        <!-- EXPLORER -->\n        <div class=\"panel active\" id=\"panel-explorer\">\n            <div class=\"panel-header\">\n                <span>EXPLORER</span>\n                <button class=\"panel-action\" onclick=\"newFile()\" title=\"New File\">+</button>\n            </div>\n            <div class=\"file-tree\">\n                <div class=\"tree-section\">\n                    <div class=\"tree-section-header expanded\" onclick=\"toggleSection(this)\">\n                        <svg class=\"chevron\" width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"currentColor\"><path d=\"M3 1L7 5L3 9V1Z\"/></svg>\n                        PROJECT\n                    </div>\n                    <div class=\"tree-items\" id=\"project-items\">\n                        <div class=\"tree-item active\" onclick=\"loadBuiltin('main')\" id=\"fi-main\">\n                            <span class=\"fi-icon nc-icon\">NC</span> main.nc\n                        </div>\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('compiler')\" id=\"fi-compiler\">\n                            <span class=\"fi-icon nc-icon\">NC</span> compiler.nc\n                        </div>\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('ui')\" id=\"fi-ui\">\n                            <span class=\"fi-icon nc-icon\">NC</span> ui.nc\n                        </div>\n                    </div>\n                </div>\n                <div class=\"tree-section\">\n                    <div class=\"tree-section-header expanded\" onclick=\"toggleSection(this)\">\n                        <svg class=\"chevron\" width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"currentColor\"><path d=\"M3 1L7 5L3 9V1Z\"/></svg>\n                        EXAMPLES\n                    </div>\n                    <div class=\"tree-items\">\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('calculator')\" id=\"fi-calculator\">\n                            <span class=\"fi-icon ex-icon\">NC</span> calculator.nc\n                        </div>\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('tutorial')\" id=\"fi-tutorial\">\n                            <span class=\"fi-icon ex-icon\">NC</span> tutorial.nc\n                        </div>\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('hello')\" id=\"fi-hello\">\n                            <span class=\"fi-icon ex-icon\">NC</span> hello.nc\n                        </div>\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('budget')\" id=\"fi-budget\">\n                            <span class=\"fi-icon ex-icon\">NC</span> budget_tracker.nc\n                        </div>\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('counter')\" id=\"fi-counter\">\n                            <span class=\"fi-icon ex-icon\">NC</span> counter.nc\n                        </div>\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('physics')\" id=\"fi-physics\">\n                            <span class=\"fi-icon ex-icon\">NC</span> game_physics.nc\n                        </div>\n                        <div class=\"tree-item\" onclick=\"loadBuiltin('fulldemo')\" id=\"fi-fulldemo\">\n                            <span class=\"fi-icon ex-icon\">NC</span> full_demo.nc\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- EXAMPLES -->\n        <div class=\"panel\" id=\"panel-examples\">\n            <div class=\"panel-header\"><span>EXAMPLES</span></div>\n            <div class=\"examples-list\">\n                <div class=\"ex-card\" onclick=\"loadBuiltin('hello')\">\n                    <div class=\"ex-icon-wrap\">👋</div>\n                    <div><div class=\"ex-title\">Hello World</div><div class=\"ex-desc\">First NATCOM program</div></div>\n                </div>\n                <div class=\"ex-card\" onclick=\"loadBuiltin('calculator')\">\n                    <div class=\"ex-icon-wrap\">🧮</div>\n                    <div><div class=\"ex-title\">Calculator</div><div class=\"ex-desc\">User input + all arithmetic</div></div>\n                </div>\n                <div class=\"ex-card\" onclick=\"loadBuiltin('budget')\">\n                    <div class=\"ex-icon-wrap\">💰</div>\n                    <div><div class=\"ex-title\">Budget Tracker</div><div class=\"ex-desc\">Loops + conditionals</div></div>\n                </div>\n                <div class=\"ex-card\" onclick=\"loadBuiltin('counter')\">\n                    <div class=\"ex-icon-wrap\">🔢</div>\n                    <div><div class=\"ex-title\">Counter</div><div class=\"ex-desc\">Repeat loops + increment</div></div>\n                </div>\n                <div class=\"ex-card\" onclick=\"loadBuiltin('physics')\">\n                    <div class=\"ex-icon-wrap\">🎮</div>\n                    <div><div class=\"ex-title\">Game Physics</div><div class=\"ex-desc\">3D viewport + random</div></div>\n                </div>\n                <div class=\"ex-card\" onclick=\"loadBuiltin('fulldemo')\">\n                    <div class=\"ex-icon-wrap\">🚀</div>\n                    <div><div class=\"ex-title\">Full Demo</div><div class=\"ex-desc\">Every NATCOM feature</div></div>\n                </div>\n            </div>\n        </div>\n\n        <!-- SEARCH -->\n        <div class=\"panel\" id=\"panel-search\">\n            <div class=\"panel-header\"><span>SEARCH</span></div>\n            <div style=\"padding:8px 12px;\">\n                <input type=\"text\" class=\"search-input\" placeholder=\"Search in all files...\" id=\"searchInput\" oninput=\"searchCode()\">\n            </div>\n            <div id=\"search-results\" class=\"search-results\"></div>\n        </div>\n\n        <!-- CHEATSHEET / LANGUAGE REFERENCE -->\n        <div class=\"panel\" id=\"panel-cheatsheet\">\n            <div class=\"panel-header\"><span>LANGUAGE REFERENCE</span></div>\n            <div class=\"cheatsheet\" id=\"cheatsheet\">\n                <div class=\"cs-section\">\n                    <div class=\"cs-title\">📦 Variables</div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Create a high speed integer named MyVar and set it to 0.')\"><code>Create a high speed integer named X and set it to 0.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Create a floating point variable named MyVar and set it to 0.0.')\"><code>Create a floating point variable named X and set it to 0.0.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Create a string named MyText and set it to &quot;Hello&quot;.')\"><code>Create a string named X and set it to \"Hello\".</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Create a boolean named MyFlag and set it to true.')\"><code>Create a boolean named X and set it to true.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Set X to 42.')\"><code>Set X to 42.</code></div>\n                </div>\n                <div class=\"cs-section\">\n                    <div class=\"cs-title\">🎯 User Input</div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Ask the user to enter a value for X.')\"><code>Ask the user to enter a value for X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Ask the user for text named Name.')\"><code>Ask the user for text named Name.</code></div>\n                </div>\n                <div class=\"cs-section\">\n                    <div class=\"cs-title\">➕ Math</div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Add 5 to X.')\"><code>Add 5 to X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Subtract 3 from X.')\"><code>Subtract 3 from X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Multiply X by 2.')\"><code>Multiply X by 2.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Divide X by 4.')\"><code>Divide X by 4.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Increment X.')\"><code>Increment X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Decrement X.')\"><code>Decrement X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Swap the values of X and Y.')\"><code>Swap the values of X and Y.</code></div>\n                </div>\n                <div class=\"cs-section\">\n                    <div class=\"cs-title\">🔢 Math Functions</div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Set Result to the square root of X.')\"><code>Set Result to the square root of X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Raise X to the power of Y.')\"><code>Raise X to the power of Y.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Set Result to the absolute value of X.')\"><code>Set Result to the absolute value of X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Set Result to the maximum of A and B.')\"><code>Set Result to the maximum of A and B.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Set Result to the minimum of A and B.')\"><code>Set Result to the minimum of A and B.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Set Result to the floor of X.')\"><code>Set Result to the floor of X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Set Result to the ceiling of X.')\"><code>Set Result to the ceiling of X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Find the remainder of A divided by B and store in Result.')\"><code>Find the remainder of A divided by B and store in Result.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Generate a random number between 1 and 100 and store in Result.')\"><code>Generate a random number between 1 and 100 and store in Result.</code></div>\n                </div>\n                <div class=\"cs-section\">\n                    <div class=\"cs-title\">📤 Output</div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Log the value of X.')\"><code>Log the value of X.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Display &quot;Hello World&quot;.')\"><code>Display \"Hello World\".</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Display the values of X and Y.')\"><code>Display the values of X and Y.</code></div>\n                </div>\n                <div class=\"cs-section\">\n                    <div class=\"cs-title\">🔀 Conditions</div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('If the X is greater than Y, then:\\n  Log the value of X.\\nOtherwise:\\n  Log the value of Y.')\"><code>If the X is greater than Y, then: ... Otherwise: ...</code></div>\n                </div>\n                <div class=\"cs-section\">\n                    <div class=\"cs-title\">🔁 Loops</div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Begin the main simulation loop.\\n  Increment X.\\n  If the X is greater than 10, then:\\n    Halt the simulation.\\n  Otherwise:\\n    Keep the simulation running.')\"><code>Begin the main simulation loop. ... Halt the simulation.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Repeat 10 times:\\n  Increment X.\\nDone.')\"><code>Repeat 10 times: ... Done.</code></div>\n                    <div class=\"cs-item\" onclick=\"insertSnippet('Keep running while X is less than 10:\\n  Increment X.\\nStop the loop.')\"><code>Keep running while X is less than 10: ...</code></div>\n                </div>\n            </div>\n        </div>\n\n        <!-- SETTINGS -->\n        <div class=\"panel\" id=\"panel-settings\">\n            <div class=\"panel-header\"><span>SETTINGS</span></div>\n            <div class=\"settings-list\">\n                <div class=\"setting-group\">\n                    <div class=\"sg-title\">COMPILER</div>\n                    <div class=\"setting-item\"><span>Target</span>\n                        <select class=\"setting-select\" id=\"targetSelect\" onchange=\"updateStatusTarget()\">\n                            <option value=\"c\">Native C (-O3)</option>\n                            <option value=\"js\">JavaScript</option>\n                        </select>\n                    </div>\n                </div>\n                <div class=\"setting-group\">\n                    <div class=\"sg-title\">EDITOR</div>\n                    <div class=\"setting-item\"><span>Font Size</span>\n                        <input type=\"number\" class=\"setting-input\" value=\"14\" min=\"10\" max=\"24\" onchange=\"setFontSize(this.value)\">\n                    </div>\n                    <div class=\"setting-item\"><span>Syntax Highlight</span>\n                        <label class=\"toggle\"><input type=\"checkbox\" checked id=\"syntaxToggle\" onchange=\"toggleSyntax(this)\"><span class=\"slider\"></span></label>\n                    </div>\n                    <div class=\"setting-item\"><span>Error Squiggles</span>\n                        <label class=\"toggle\"><input type=\"checkbox\" checked id=\"errorToggle\"><span class=\"slider\"></span></label>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <!-- SIDEBAR RESIZE -->\n    <div class=\"resize-handle\" id=\"resizeHandle\"></div>\n\n    <!-- EDITOR AREA -->\n    <div class=\"editor-area\">\n\n        <!-- TABS -->\n        <div class=\"tab-bar\" id=\"tabBar\">\n            <div class=\"tab active\" id=\"tab-main\" onclick=\"switchTab('main')\">\n                <span class=\"tab-icon nc-icon\">NC</span>\n                <span class=\"tab-name\">main.nc</span>\n                <span class=\"tab-dirty\" id=\"dirty-main\" style=\"display:none\">●</span>\n                <span class=\"tab-close\" onclick=\"closeTab(event,'main')\">×</span>\n            </div>\n        </div>\n\n        <!-- EDITOR + HIGHLIGHT WRAPPER -->\n        <div class=\"editor-wrapper\" id=\"editorWrapper\">\n            <!-- Line numbers -->\n            <div class=\"line-numbers\" id=\"lineNumbers\"></div>\n\n            <!-- Error gutter -->\n            <div class=\"error-gutter\" id=\"errorGutter\"></div>\n\n            <!-- Highlight overlay (sits BEHIND textarea) -->\n            <div class=\"highlight-host\" id=\"highlightHost\">\n                <pre class=\"highlight-pre\" id=\"highlightPre\"></pre>\n            </div>\n\n            <!-- The actual textarea -->\n            <textarea id=\"editor\" class=\"editor\" spellcheck=\"false\"\n                oninput=\"onEditorInput()\"\n                onkeydown=\"handleKey(event)\"\n                onscroll=\"syncScroll()\"\n                onclick=\"updateCursorStatus()\"\n                onkeyup=\"updateCursorStatus()\"\n            ></textarea>\n        </div>\n\n        <!-- TERMINAL RESIZE -->\n        <div class=\"hresize-handle\" id=\"hresizeHandle\"></div>\n\n        <!-- TERMINAL -->\n        <div class=\"terminal-panel\" id=\"terminalPanel\">\n            <div class=\"terminal-tabs\">\n                <div class=\"term-tab active\" id=\"tabOutput\" onclick=\"switchTermTab('output')\">\n                    <svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"4 17 10 11 4 5\"/><line x1=\"12\" y1=\"19\" x2=\"20\" y2=\"19\"/></svg>\n                    OUTPUT\n                </div>\n                <div class=\"term-tab\" id=\"tabInput\" onclick=\"switchTermTab('input')\">\n                    <svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M20 4L4 12L20 20V4Z\"/></svg>\n                    INPUT\n                </div>\n                <div class=\"term-tab\" id=\"errTab\" onclick=\"switchToErrorTab()\" style=\"display:none\">\n                    <svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"#ff6b6b\"><path d=\"M12 2L1 21h22L12 2z\"/></svg>\n                    ERRORS\n                </div>\n                <div class=\"term-actions\">\n                    <button class=\"term-btn\" onclick=\"clearTerminal()\" title=\"Clear\">\n                        <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"3 6 5 6 21 6\"/><path d=\"M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2\"/></svg>\n                    </button>\n                    <button class=\"term-btn\" onclick=\"toggleTerminal()\" title=\"Toggle\" id=\"termToggleBtn\">⌃</button>\n                </div>\n            </div>\n            \n            <div id=\"terminal\" class=\"terminal-body\">\n                <div class=\"term-line system\">\n                    <span class=\"term-prompt\">natcom@studio</span><span class=\"term-arr\">▶</span>\n                    <span class=\"term-msg\">NATCOM Studio ready. Open a file or write code and press <kbd>Ctrl+Enter</kbd> to run.</span>\n                </div>\n            </div>\n\n            <div id=\"terminalInputArea\" class=\"terminal-body\" style=\"display:none; padding: 0;\">\n                <textarea id=\"stdinInput\" placeholder=\"Enter standard input (stdin) here before clicking Run...\" spellcheck=\"false\" style=\"width: 100%; height: 100%; border: none; outline: none; resize: none; background: #2B2B2B; color: #A9B7C6; padding: 12px 20px; font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace; font-size: 13px; line-height: 1.6; scrollbar-width: thin; scrollbar-color: #4D4D4D transparent;\"></textarea>\n            </div>\n        </div>\n        \n        <!-- ERROR PANEL (shows when errors detected) -->\n        <div class=\"error-panel\" id=\"errorPanel\" style=\"display:none\">\n            <div class=\"ep-header\">\n                <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#ff6b6b\"><path d=\"M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z\"/></svg>\n                <span>PROBLEMS</span>\n                <span id=\"ep-count\" class=\"ep-count\">0</span>\n                <button class=\"ep-close\" onclick=\"closeErrorPanel()\">×</button>\n            </div>\n            <div class=\"ep-list\" id=\"epList\"></div>\n        </div>\n    </div>\n</div>\n\n<!-- STATUS BAR -->\n<div class=\"statusbar\">\n    <div class=\"status-left\">\n        <span class=\"status-item status-branch\">\n            <svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"6\" y1=\"3\" x2=\"6\" y2=\"15\"/><circle cx=\"18\" cy=\"6\" r=\"3\"/><circle cx=\"6\" cy=\"18\" r=\"3\"/><path d=\"M18 9a9 9 0 0 1-9 9\"/></svg>\n            master\n        </span>\n        <span class=\"status-item status-errors\" id=\"statusErrors\">✓ No Problems</span>\n    </div>\n    <div class=\"status-right\">\n        <span class=\"status-item\" id=\"statusCursor\">Ln 1, Col 1</span>\n        <span class=\"status-item\" id=\"statusLines\">1 lines</span>\n        <span class=\"status-item\">NATCOM .nc</span>\n        <span class=\"status-item\">UTF-8</span>\n        <span class=\"status-item status-target\" id=\"statusTarget\">⚡ Native C</span>\n    </div>\n</div>\n\n<!-- NEW FILE MODAL -->\n<div class=\"modal-overlay\" id=\"newFileModal\" style=\"display:none\" onclick=\"closeNewFileModal(event)\">\n    <div class=\"modal\" onclick=\"event.stopPropagation()\">\n        <h3>New NATCOM File</h3>\n        <input type=\"text\" id=\"newFileName\" class=\"modal-input\" placeholder=\"filename (without .nc)\" autofocus>\n        <div class=\"modal-actions\">\n            <button class=\"modal-btn secondary\" onclick=\"document.getElementById('newFileModal').style.display='none'\">Cancel</button>\n            <button class=\"modal-btn primary\" onclick=\"createNewFile()\">Create .nc File</button>\n        </div>\n    </div>\n</div>\n\n<script src=\"script.js\"></script>\n</body>\n</html>\n\n\n\n\nEOF_NATCOM_BOOTSTRAP");
    system("cat << \'EOF_NATCOM_BOOTSTRAP\' > ui/style.css\n/* =====================================================================\n   NATCOM STUDIO — Premium IDE Stylesheet v2.0\n   Full VS Code / JetBrains inspired design\n   ===================================================================== */\n:root {\n  --bg0:       #0a0a10;\n  --bg1:       #0e0e18;\n  --bg2:       #121220;\n  --bg3:       #181828;\n  --bg4:       #1e1e32;\n  --bg-hover:  rgba(255,255,255,0.045);\n  --bg-active: rgba(0,255,204,0.07);\n  --bg-tab:    #141420;\n  --bg-tab-a:  #0e0e18;\n\n  --ac:        #00ffcc;\n  --ac-dim:    rgba(0,255,204,0.12);\n  --ac-glow:   rgba(0,255,204,0.3);\n  --ac2:       #7c6af7;\n  --ac3:       #f7a06a;\n  --ac-red:    #ff6b6b;\n  --ac-yellow: #ffd700;\n\n  --tx0: #f0f2f8;\n  --tx1: #c9cdd8;\n  --tx2: #8891a4;\n  --tx3: #4a5168;\n  --tx4: #2a2d3e;\n\n  /* Syntax */\n  --sy-kw:   #c792ea;\n  --sy-str:  #c3e88d;\n  --sy-num:  #f78c6c;\n  --sy-cmt:  #4a5568;\n  --sy-fn:   #82aaff;\n  --sy-var:  #eeffff;\n  --sy-op:   #89ddff;\n  --sy-bool: #ff9cac;\n  --sy-io:   #ffd700;\n  --sy-err:  rgba(255,80,80,0.15);\n  --sy-warn: rgba(255,200,0,0.12);\n\n  --border:   rgba(255,255,255,0.055);\n  --border-a: rgba(0,255,204,0.28);\n  --radius:   6px;\n  --font-ui:  'Inter', -apple-system, sans-serif;\n  --font-code:'Fira Code', 'Consolas', monospace;\n\n  --titlebar-h: 40px;\n  --menubar-h:  30px;\n  --activity-w: 50px;\n  --sidebar-w:  260px;\n  --statusbar-h:22px;\n  --tab-h:      36px;\n  --terminal-h: 210px;\n}\n\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\nhtml, body { height: 100%; overflow: hidden; background: var(--bg0); color: var(--tx1); font-family: var(--font-ui); font-size: 13px; -webkit-font-smoothing: antialiased; }\n\n/* ======================== TITLE BAR ======================== */\n.titlebar {\n  height: var(--titlebar-h); background: var(--bg0);\n  border-bottom: 1px solid var(--border);\n  display: flex; align-items: center; justify-content: space-between;\n  padding: 0 14px; user-select: none; flex-shrink: 0; position: relative; z-index: 100;\n}\n.titlebar-left  { display: flex; align-items: center; gap: 14px; }\n.titlebar-center{ position: absolute; left: 50%; transform: translateX(-50%); }\n.titlebar-right { display: flex; align-items: center; gap: 8px; }\n\n.traffic-lights { display: flex; gap: 7px; }\n.tl { width: 12px; height: 12px; border-radius: 50%; cursor: pointer; transition: filter .2s; }\n.tl:hover { filter: brightness(1.4) saturate(1.2); }\n.tl-red    { background: #ff5f57; box-shadow: 0 0 4px #ff5f5760; }\n.tl-yellow { background: #febc2e; box-shadow: 0 0 4px #febc2e60; }\n.tl-green  { background: #28c840; box-shadow: 0 0 4px #28c84060; }\n\n.app-brand { display: flex; align-items: center; gap: 8px; }\n.brand-name { font-size: 13px; font-weight: 700; letter-spacing: .8px; color: var(--tx0); }\n.brand-studio { color: var(--ac); font-weight: 400; text-shadow: 0 0 10px var(--ac-glow); }\n.brand-version { font-size: 10px; color: var(--tx3); background: var(--bg4); border: 1px solid var(--border); border-radius: 3px; padding: 1px 5px; }\n\n.breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--tx2); }\n.bc-root { color: var(--tx3); }\n.bc-sep  { color: var(--tx4); }\n.bc-file { color: var(--tx1); font-weight: 500; }\n\n.sovereign-status { display: flex; align-items: center; gap: 7px; font-size: 11px; color: var(--tx3); }\n.pulse-dot { width: 7px; height: 7px; background: var(--ac); border-radius: 50%; box-shadow: 0 0 6px var(--ac); animation: pulse 2s ease-in-out infinite; }\n@keyframes pulse { 0%,100%{ opacity:.4; } 50%{ opacity:1; } }\n\n/* ======================== MENU BAR ======================== */\n.menubar {\n  height: var(--menubar-h); background: var(--bg0);\n  border-bottom: 1px solid var(--border);\n  display: flex; align-items: center; justify-content: space-between;\n  padding: 0 var(--activity-w); flex-shrink: 0;\n}\n.menubar-left { display: flex; gap: 2px; }\n.menu-item { background: none; border: none; color: var(--tx2); font-family: var(--font-ui); font-size: 12px; padding: 3px 9px; border-radius: 4px; cursor: pointer; transition: .12s; }\n.menu-item:hover { background: var(--bg-hover); color: var(--tx0); }\n\n.menubar-actions { display: flex; align-items: center; gap: 8px; }\n\n.error-badge { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--ac-red); background: rgba(255,107,107,0.1); border: 1px solid rgba(255,107,107,0.25); border-radius: var(--radius); padding: 2px 8px; cursor: pointer; }\n\n.run-btn, .build-btn { display: flex; align-items: center; gap: 5px; border: none; border-radius: var(--radius); font-family: var(--font-ui); font-size: 11px; font-weight: 600; padding: 4px 13px; cursor: pointer; transition: all .18s; }\n.run-btn { background: var(--ac); color: #000; box-shadow: 0 0 14px var(--ac-glow); }\n.run-btn:hover { box-shadow: 0 0 24px var(--ac-glow); transform: translateY(-1px); }\n.run-btn:active { transform: translateY(0); }\n.run-btn.loading { opacity: .55; pointer-events: none; }\n.build-btn { background: transparent; color: var(--tx2); border: 1px solid var(--border); }\n.build-btn:hover { border-color: var(--border-a); color: var(--ac); }\n\n/* ======================== IDE LAYOUT ======================== */\n.ide-layout { display: flex; height: calc(100vh - var(--titlebar-h) - var(--menubar-h) - var(--statusbar-h)); overflow: hidden; }\n\n/* ======================== ACTIVITY BAR ======================== */\n.activity-bar {\n  width: var(--activity-w); background: var(--bg0); border-right: 1px solid var(--border);\n  display: flex; flex-direction: column; align-items: center;\n  padding: 8px 0; gap: 2px; flex-shrink: 0;\n}\n.activity-btn { width: 38px; height: 38px; background: none; border: none; cursor: pointer; color: var(--tx3); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; transition: .14s; position: relative; }\n.activity-btn:hover { color: var(--tx1); background: var(--bg-hover); }\n.activity-btn.active { color: var(--ac); background: var(--bg-active); border-left: 2px solid var(--ac); border-radius: 0 var(--radius) var(--radius) 0; }\n.activity-spacer { flex: 1; }\n\n/* ======================== SIDEBAR ======================== */\n.sidebar { width: var(--sidebar-w); background: var(--bg1); border-right: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden; flex-shrink: 0; }\n.panel { display: none; flex-direction: column; flex: 1; overflow: hidden; }\n.panel.active { display: flex; }\n.panel-header { padding: 10px 14px 7px; display: flex; align-items: center; justify-content: space-between; font-size: 10px; font-weight: 700; letter-spacing: 1.6px; color: var(--tx2); text-transform: uppercase; flex-shrink: 0; }\n.panel-action { background: none; border: none; color: var(--tx2); cursor: pointer; font-size: 18px; line-height: 1; padding: 1px 5px; border-radius: 3px; transition: .14s; }\n.panel-action:hover { background: var(--bg-hover); color: var(--ac); }\n\n/* FILE TREE */\n.file-tree { flex: 1; overflow-y: auto; padding-bottom: 12px; }\n.file-tree::-webkit-scrollbar { width: 3px; }\n.file-tree::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }\n.tree-section { margin-bottom: 2px; }\n.tree-section-header { display: flex; align-items: center; gap: 6px; padding: 5px 10px; font-size: 10px; font-weight: 700; letter-spacing: 1px; color: var(--tx2); cursor: pointer; text-transform: uppercase; user-select: none; }\n.tree-section-header:hover { color: var(--tx1); }\n.chevron { transition: transform .15s; flex-shrink: 0; }\n.tree-section-header.expanded .chevron { transform: rotate(90deg); }\n.tree-items { padding-left: 4px; }\n.tree-item { display: flex; align-items: center; gap: 8px; padding: 4px 14px; border-radius: var(--radius); cursor: pointer; font-size: 12.5px; color: var(--tx1); transition: all .1s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.tree-item:hover { background: var(--bg-hover); }\n.tree-item.active { background: var(--bg-active); color: var(--ac); }\n.fi-icon { font-size: 9px; font-weight: 700; letter-spacing: .5px; padding: 1px 4px; border-radius: 3px; flex-shrink: 0; font-family: var(--font-ui); }\n.nc-icon  { background: rgba(0,255,204,0.12); color: var(--ac); }\n.ex-icon  { background: rgba(255,208,0,0.12);  color: var(--ac-yellow); }\n\n/* EXAMPLES */\n.examples-list { padding: 8px 10px; display: flex; flex-direction: column; gap: 5px; overflow-y: auto; }\n.ex-card { display: flex; align-items: center; gap: 10px; background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); padding: 9px 12px; cursor: pointer; transition: all .15s; }\n.ex-card:hover { border-color: var(--border-a); background: var(--bg-active); }\n.ex-icon-wrap { font-size: 20px; flex-shrink: 0; }\n.ex-title { font-size: 12px; font-weight: 600; color: var(--tx0); }\n.ex-desc  { font-size: 11px; color: var(--tx2); margin-top: 1px; }\n\n/* SEARCH */\n.search-input { width: 100%; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); color: var(--tx1); font-size: 12px; font-family: var(--font-ui); padding: 6px 10px; outline: none; transition: .18s; }\n.search-input:focus { border-color: var(--border-a); }\n.search-results { flex: 1; overflow-y: auto; padding: 4px 0; }\n.sr-item { padding: 5px 14px; cursor: pointer; font-family: var(--font-code); font-size: 11px; color: var(--tx2); transition: .1s; }\n.sr-item:hover { background: var(--bg-hover); color: var(--tx1); }\n.sr-file { color: var(--ac2); font-size: 10px; margin-bottom: 1px; }\n.sr-hl { color: var(--ac); }\n\n/* CHEATSHEET */\n.cheatsheet { flex: 1; overflow-y: auto; padding: 8px 10px 16px; }\n.cheatsheet::-webkit-scrollbar { width: 3px; }\n.cheatsheet::-webkit-scrollbar-thumb { background: var(--border); }\n.cs-section { margin-bottom: 12px; }\n.cs-title { font-size: 10px; font-weight: 700; letter-spacing: 1px; color: var(--tx2); text-transform: uppercase; padding: 6px 4px 4px; border-bottom: 1px solid var(--border); margin-bottom: 4px; }\n.cs-item { padding: 5px 6px; border-radius: 4px; cursor: pointer; transition: .12s; }\n.cs-item:hover { background: var(--bg-active); }\n.cs-item code { font-family: var(--font-code); font-size: 10.5px; color: var(--sy-kw); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n\n/* SETTINGS */\n.settings-list { padding: 10px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }\n.setting-group { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }\n.sg-title { padding: 7px 12px; font-size: 10px; font-weight: 700; letter-spacing: 1px; color: var(--tx2); border-bottom: 1px solid var(--border); text-transform: uppercase; }\n.setting-item { display: flex; align-items: center; justify-content: space-between; padding: 7px 12px; border-bottom: 1px solid var(--border); font-size: 12px; color: var(--tx1); }\n.setting-item:last-child { border-bottom: none; }\n.setting-select { background: var(--bg1); border: 1px solid var(--border); border-radius: 4px; color: var(--tx1); font-size: 11px; padding: 3px 6px; outline: none; cursor: pointer; }\n.setting-input  { width: 56px; background: var(--bg1); border: 1px solid var(--border); border-radius: 4px; color: var(--tx1); font-size: 11px; padding: 3px 6px; outline: none; text-align: center; }\n.toggle { position: relative; display: inline-block; width: 34px; height: 18px; }\n.toggle input { opacity: 0; width: 0; height: 0; }\n.slider { position: absolute; inset: 0; background: var(--bg1); border-radius: 18px; border: 1px solid var(--border); cursor: pointer; transition: .18s; }\n.slider:before { content: ''; position: absolute; width: 12px; height: 12px; background: var(--tx3); border-radius: 50%; bottom: 2px; left: 2px; transition: .18s; }\n.toggle input:checked + .slider { background: var(--ac-dim); border-color: var(--border-a); }\n.toggle input:checked + .slider:before { transform: translateX(16px); background: var(--ac); }\n\n/* ======================== RESIZE HANDLES ======================== */\n.resize-handle  { width: 3px; background: transparent; cursor: col-resize; flex-shrink: 0; transition: background .15s; }\n.resize-handle:hover, .resize-handle.resizing { background: var(--ac); }\n.hresize-handle { height: 4px; background: var(--border); cursor: row-resize; flex-shrink: 0; transition: background .15s; }\n.hresize-handle:hover, .hresize-handle.resizing { background: var(--ac); }\n\n/* ======================== EDITOR AREA ======================== */\n.editor-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }\n\n/* TABS */\n.tab-bar { height: var(--tab-h); background: var(--bg-tab); border-bottom: 1px solid var(--border); display: flex; align-items: flex-end; overflow-x: auto; flex-shrink: 0; }\n.tab-bar::-webkit-scrollbar { height: 2px; }\n.tab-bar::-webkit-scrollbar-thumb { background: var(--border); }\n.tab { height: 34px; display: flex; align-items: center; gap: 6px; padding: 0 13px; font-size: 12px; color: var(--tx2); border-right: 1px solid var(--border); cursor: pointer; background: var(--bg-tab); flex-shrink: 0; transition: .1s; border-top: 2px solid transparent; white-space: nowrap; }\n.tab:hover  { color: var(--tx1); background: var(--bg-hover); }\n.tab.active { background: var(--bg-tab-a); color: var(--tx0); border-top-color: var(--ac); }\n.tab-icon   { font-family: var(--font-ui); font-size: 8px; font-weight: 700; padding: 1px 3px; border-radius: 2px; flex-shrink: 0; }\n.tab .nc-icon { background: rgba(0,255,204,0.1); color: var(--ac); }\n.tab-name   { font-size: 12px; }\n.tab-dirty  { color: var(--ac-yellow); font-size: 14px; }\n.tab-close  { opacity: 0; font-size: 14px; line-height: 1; padding: 1px 3px; border-radius: 3px; transition: .1s; margin-left: 3px; }\n.tab:hover .tab-close { opacity: .55; }\n.tab-close:hover { opacity: 1 !important; background: rgba(255,255,255,0.1); }\n\n/* EDITOR WRAPPER */\n.editor-wrapper { flex: 1; display: flex; overflow: hidden; position: relative; background: var(--bg2); }\n\n.line-numbers { width: 48px; padding: 14px 8px 14px 0; text-align: right; font-family: var(--font-code); font-size: 13px; line-height: 1.65; color: var(--tx3); background: var(--bg2); border-right: 1px solid var(--border); user-select: none; overflow: hidden; flex-shrink: 0; transition: color .1s; }\n.line-numbers .ln-err  { color: var(--ac-red); }\n.line-numbers .ln-warn { color: var(--ac-yellow); }\n\n.error-gutter { width: 16px; background: var(--bg2); flex-shrink: 0; position: relative; overflow: hidden; }\n.eg-dot { position: absolute; right: 3px; width: 8px; height: 8px; border-radius: 50%; transform: translateY(-50%); }\n.eg-dot.error { background: var(--ac-red); box-shadow: 0 0 4px var(--ac-red); }\n.eg-dot.warn  { background: var(--ac-yellow); box-shadow: 0 0 4px var(--ac-yellow); }\n\n/* SYNTAX HIGHLIGHT OVERLAY */\n.highlight-host { position: absolute; top: 0; left: 64px; right: 0; bottom: 0; pointer-events: none; overflow: hidden; }\n.highlight-pre { font-family: var(--font-code); font-size: 14px; line-height: 1.65; padding: 14px 16px; margin: 0; white-space: pre; word-wrap: normal; color: transparent; /* text is invisible — only backgrounds/spans show */ }\n.highlight-pre .kw   { color: var(--sy-kw); }\n.highlight-pre .str  { color: var(--sy-str); }\n.highlight-pre .num  { color: var(--sy-num); }\n.highlight-pre .cmt  { color: var(--sy-cmt); font-style: italic; }\n.highlight-pre .io   { color: var(--sy-io); font-weight: 500; }\n.highlight-pre .fn   { color: var(--sy-fn); }\n.highlight-pre .bool { color: var(--sy-bool); }\n.highlight-pre .op   { color: var(--sy-op); }\n.highlight-pre .err-line  { background: var(--sy-err); display: block; width: 100%; text-decoration: underline wavy var(--ac-red); text-decoration-skip-ink: none; }\n.highlight-pre .warn-line { background: var(--sy-warn); display: block; width: 100%; text-decoration: underline wavy var(--ac-yellow); text-decoration-skip-ink: none; }\n\n/* TEXTAREA */\n.editor {\n  flex: 1; background: transparent; border: none; outline: none; resize: none;\n  color: var(--tx1); caret-color: var(--ac);\n  font-family: var(--font-code); font-size: 14px; line-height: 1.65;\n  padding: 14px 16px; margin: 0; white-space: pre; overflow: auto;\n  box-sizing: border-box; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;\n  tab-size: 4;\n  position: absolute; top: 0; left: 64px; right: 0; bottom: 0;\n  z-index: 2; /* on top of highlight layer */\n  scrollbar-width: thin; scrollbar-color: #2a2a44 transparent;\n}\n.editor::-webkit-scrollbar { width: 8px; height: 8px; }\n.editor::-webkit-scrollbar-track { background: transparent; }\n.editor::-webkit-scrollbar-thumb { background: #2a2a44; border-radius: 4px; }\n.editor::-webkit-scrollbar-thumb:hover { background: #3a3a60; }\n\n/* ======================== ERROR PANEL ======================== */\n.error-panel { background: var(--bg1); border-top: 1px solid rgba(255,107,107,0.2); flex-shrink: 0; max-height: 140px; overflow-y: auto; }\n.ep-header { display: flex; align-items: center; gap: 8px; padding: 7px 14px; font-size: 11px; font-weight: 600; letter-spacing: .8px; color: var(--tx2); text-transform: uppercase; border-bottom: 1px solid var(--border); position: sticky; top: 0; background: var(--bg1); z-index: 1; }\n.ep-count { background: var(--ac-red); color: #fff; font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 10px; margin-left: 2px; }\n.ep-close { background: none; border: none; color: var(--tx2); cursor: pointer; font-size: 16px; margin-left: auto; padding: 1px 5px; border-radius: 3px; transition: .1s; }\n.ep-close:hover { background: var(--bg-hover); color: var(--tx0); }\n.ep-list { padding: 4px 0; }\n.ep-item { display: flex; align-items: flex-start; gap: 10px; padding: 5px 14px; cursor: pointer; transition: .1s; border-bottom: 1px solid var(--border); }\n.ep-item:last-child { border-bottom: none; }\n.ep-item:hover { background: var(--bg-hover); }\n.ep-icon-err  { color: var(--ac-red);    flex-shrink: 0; margin-top: 1px; }\n.ep-icon-warn { color: var(--ac-yellow); flex-shrink: 0; margin-top: 1px; }\n.ep-line { font-size: 11px; color: var(--tx2); flex-shrink: 0; font-family: var(--font-code); }\n.ep-msg  { font-size: 12px; color: var(--tx1); flex: 1; }\n.ep-fix  { font-size: 11px; color: var(--ac); cursor: pointer; white-space: nowrap; }\n.ep-fix:hover { text-decoration: underline; }\n.ep-suggestion { font-size: 11px; color: var(--ac2); margin-top: 2px; }\n\n/* ======================== TERMINAL ======================== */\n.terminal-panel { height: var(--terminal-h); display: flex; flex-direction: column; background: #0a0a10; flex-shrink: 0; overflow: hidden; transition: height .2s ease; }\n.terminal-panel.collapsed { height: 36px; }\n\n.terminal-tabs { height: 36px; display: flex; align-items: center; border-bottom: 1px solid var(--border); padding: 0 6px; gap: 2px; flex-shrink: 0; }\n.term-tab { display: flex; align-items: center; gap: 5px; padding: 3px 11px; font-size: 11px; font-weight: 600; color: var(--tx2); letter-spacing: .5px; cursor: pointer; border-radius: 4px 4px 0 0; transition: .1s; user-select: none; }\n.term-tab.active { color: var(--tx0); background: rgba(255,255,255,0.04); }\n.term-tab:hover  { color: var(--tx1); }\n.term-actions { margin-left: auto; display: flex; gap: 2px; }\n.term-btn { background: none; border: none; color: var(--tx3); cursor: pointer; padding: 4px 7px; border-radius: 4px; font-size: 13px; transition: .14s; }\n.term-btn:hover { background: var(--bg-hover); color: var(--tx1); }\n\n.terminal-body { flex: 1; overflow-y: auto; padding: 12px 20px; font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace; font-size: 13px; line-height: 1.6; scrollbar-width: thin; scrollbar-color: #2a2a44 transparent; background: #2B2B2B; color: #A9B7C6; }\n.terminal-body::-webkit-scrollbar { width: 8px; }\n.terminal-body::-webkit-scrollbar-thumb { background: #4D4D4D; border-radius: 4px; }\n\n.term-line { display: flex; gap: 8px; animation: fadeUp .18s ease forwards; padding: 1px 0; }\n@keyframes fadeUp { from{opacity:0;transform:translateY(3px);}to{opacity:1;transform:none;} }\n\n.term-prompt { display: none; }\n.term-arr    { display: none; }\n.term-msg    { white-space: pre-wrap; word-break: break-all; width: 100%; }\n.term-line.system   .term-msg { color: #808080; font-style: italic; }\n.term-line.success  .term-msg { color: #629755; }\n.term-line.error    .term-msg { color: #CC666E; }\n.term-line.warn     .term-msg { color: #FFC66D; }\n.term-line.output   .term-msg { color: #A9B7C6; }\n.term-line.compiler .term-msg { color: #56A8F5; }\n.term-line.input    .term-msg { color: #20999D; }\nkbd { background: var(--bg4); border: 1px solid var(--border); border-radius: 3px; padding: 0 4px; font-family: var(--font-code); font-size: 11px; }\n\n/* ======================== STATUS BAR ======================== */\n.statusbar { height: var(--statusbar-h); background: var(--ac); color: #000; display: flex; align-items: center; justify-content: space-between; padding: 0 10px; font-size: 11px; font-weight: 500; flex-shrink: 0; }\n.status-left, .status-right { display: flex; align-items: center; gap: 10px; }\n.status-item { display: flex; align-items: center; gap: 4px; opacity: .8; cursor: default; transition: opacity .1s; }\n.status-item:hover { opacity: 1; }\n.status-branch { font-weight: 700; opacity: 1; }\n.status-target { font-weight: 700; opacity: 1; background: rgba(0,0,0,.15); padding: 1px 7px; border-radius: 3px; }\n.status-errors.has-error { color: #ff0000; font-weight: 700; }\n\n/* ======================== MODAL ======================== */\n.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.55); display: flex; align-items: center; justify-content: center; z-index: 999; backdrop-filter: blur(4px); }\n.modal { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 22px; width: 360px; box-shadow: 0 24px 60px rgba(0,0,0,.6); }\n.modal h3 { font-size: 14px; font-weight: 700; color: var(--tx0); margin-bottom: 14px; }\n.modal-input { width: 100%; background: var(--bg1); border: 1px solid var(--border); border-radius: var(--radius); color: var(--tx1); font-size: 13px; font-family: var(--font-code); padding: 8px 11px; outline: none; transition: .18s; margin-bottom: 14px; }\n.modal-input:focus { border-color: var(--border-a); }\n.modal-actions { display: flex; gap: 8px; justify-content: flex-end; }\n.modal-btn { padding: 6px 16px; border-radius: var(--radius); border: none; font-family: var(--font-ui); font-size: 12px; cursor: pointer; transition: .15s; }\n.modal-btn.primary   { background: var(--ac); color: #000; font-weight: 600; }\n.modal-btn.primary:hover { box-shadow: 0 0 14px var(--ac-glow); }\n.modal-btn.secondary { background: var(--bg-hover); color: var(--tx2); border: 1px solid var(--border); }\n\n\n\n\nEOF_NATCOM_BOOTSTRAP");
    system("cat << \'EOF_NATCOM_BOOTSTRAP\' > ui/about.html\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>NATCOM — Created by Beon Binesh</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Fira+Code:wght@400;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root {\n      --ac:  #ff007f; /* Neon Pink */\n      --ac2: #00f0ff; /* Cyan */\n      --ac3: #ffb700; /* Neon Orange */\n      --bg:  #110022; /* Deep Purple bg */\n    }\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n    html { scroll-behavior: smooth; }\n    body {\n      background: var(--bg) url('data:image/svg+xml;utf8,<svg width=\"4\" height=\"4\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"4\" height=\"4\" fill=\"none\"/><path d=\"M0 2h4v1H0z\" fill=\"rgba(255,255,255,0.03)\"/></svg>');\n      background-size: 4px 4px;\n      color: #ffb700;\n      font-family: 'Press Start 2P', monospace;\n      min-height: 100vh;\n      overflow-x: hidden;\n      text-transform: uppercase;\n      line-height: 1.8;\n      text-shadow: 2px 2px 0px rgba(255,0,127,0.5);\n    }\n    /* CRT Scanline Overlay */\n    body::before {\n      content: \" \";\n      display: block;\n      position: fixed;\n      top: 0; left: 0; bottom: 0; right: 0;\n      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n      z-index: 9999;\n      background-size: 100% 4px, 6px 100%;\n      pointer-events: none;\n    }\n\n    /* ── PARTICLES CANVAS ── */\n    #particles { position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.3; }\n\n    /* ── HERO ── */\n    .hero {\n      min-height: 100vh;\n      display: flex; flex-direction: column; align-items: center; justify-content: center;\n      position: relative; z-index: 1; padding: 60px 20px;\n      text-align: center;\n    }\n\n    /* ── NATCOM BADGE ── */\n    .natcom-badge {\n      display: inline-flex; align-items: center; gap: 10px;\n      background: rgba(0,255,204,0.06); border: 1px solid rgba(0,255,204,0.25);\n      border-radius: 50px; padding: 8px 20px; margin-bottom: 48px;\n      font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;\n      color: var(--ac); animation: fadeInDown .7s ease forwards;\n    }\n    .natcom-badge svg { animation: spin 6s linear infinite; }\n    @keyframes spin { from{transform:rotate(0deg);} to{transform:rotate(360deg);} }\n    @keyframes fadeInDown { from{opacity:0;transform:translateY(-20px);} to{opacity:1;transform:none;} }\n    @keyframes fadeInUp   { from{opacity:0;transform:translateY(30px);}  to{opacity:1;transform:none;} }\n    @keyframes fadeIn     { from{opacity:0;} to{opacity:1;} }\n    @keyframes scaleIn    { from{opacity:0;transform:scale(.85);} to{opacity:1;transform:scale(1);} }\n\n    /* ── PHOTO ── */\n    .photo-wrapper {\n      position: relative; width: 200px; height: 200px; margin-bottom: 36px;\n      animation: scaleIn .8s .2s ease both;\n    }\n    .photo-wrapper::before {\n      content: '';\n      position: absolute; inset: -3px;\n      border-radius: 50%;\n      background: conic-gradient(var(--ac), var(--ac2), var(--ac3), var(--ac));\n      animation: spin 4s linear infinite;\n    }\n    .photo-wrapper::after {\n      content: '';\n      position: absolute; inset: -8px;\n      border-radius: 50%;\n      background: conic-gradient(transparent 70%, rgba(0,255,204,.15) 100%);\n      animation: spin 3s linear infinite reverse;\n    }\n    .photo-inner {\n      position: absolute; inset: 3px;\n      border-radius: 50%; overflow: hidden;\n      border: 3px solid var(--bg);\n      z-index: 2;\n      box-shadow: 0 0 40px rgba(0,255,204,.25), 0 0 80px rgba(124,106,247,.15);\n    }\n    .photo-inner img {\n      width: 100%; height: 100%; object-fit: cover; object-position: top;\n    }\n    .online-dot {\n      position: absolute; bottom: 12px; right: 12px;\n      width: 18px; height: 18px; background: #00e676;\n      border-radius: 50%; border: 3px solid var(--bg); z-index: 3;\n      box-shadow: 0 0 8px #00e676; animation: pulse 2s infinite;\n    }\n    @keyframes pulse { 0%,100%{opacity:.6;} 50%{opacity:1;} }\n\n    /* ── NAME + TITLE ── */\n    .creator-name {\n      font-size: clamp(36px, 7vw, 70px);\n      font-weight: 900; letter-spacing: -2px; line-height: 1;\n      background: linear-gradient(135deg, #fff 0%, var(--ac) 50%, var(--ac2) 100%);\n      -webkit-background-clip: text; -webkit-text-fill-color: transparent;\n      background-clip: text;\n      animation: fadeInUp .8s .3s ease both;\n      margin-bottom: 12px;\n    }\n    .creator-role {\n      font-size: 16px; font-weight: 400; color: rgba(255,255,255,.45);\n      letter-spacing: .5px; animation: fadeInUp .8s .4s ease both;\n      margin-bottom: 6px;\n    }\n    .creator-tagline {\n      font-size: 13px; color: rgba(0,255,204,.7); letter-spacing: 1px;\n      font-weight: 500; animation: fadeInUp .8s .45s ease both;\n      margin-bottom: 36px;\n    }\n\n    /* ── NATCOM STATEMENT ── */\n    .statement-card {\n      background: rgba(255,255,255,.03);\n      border: 1px solid rgba(0,255,204,.15);\n      border-radius: 16px;\n      max-width: 700px;\n      padding: 36px 40px;\n      margin: 0 auto 48px;\n      animation: fadeInUp .8s .5s ease both;\n      position: relative; overflow: hidden;\n    }\n    .statement-card::before {\n      content: '';\n      position: absolute; inset: 0;\n      background: radial-gradient(ellipse at 50% 0%, rgba(0,255,204,.06), transparent 70%);\n    }\n    .statement-card h2 {\n      font-size: 22px; font-weight: 700; color: var(--ac);\n      margin-bottom: 14px; letter-spacing: -.3px;\n    }\n    .statement-card p {\n      font-size: 15px; line-height: 1.8; color: rgba(255,255,255,.65);\n    }\n    .statement-card p strong { color: rgba(255,255,255,.9); }\n\n    /* ── CREDITS GRID ── */\n    .credits-grid {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n      gap: 16px; max-width: 800px; margin: 0 auto 48px;\n      animation: fadeInUp .8s .6s ease both;\n    }\n    .credit-card {\n      background: rgba(255,255,255,.03);\n      border: 1px solid rgba(255,255,255,.07);\n      border-radius: 12px; padding: 20px; text-align: center;\n      transition: all .2s;\n    }\n    .credit-card:hover { border-color: rgba(0,255,204,.3); transform: translateY(-3px); background: rgba(0,255,204,.04); }\n    .credit-icon { font-size: 32px; margin-bottom: 10px; }\n    .credit-label { font-size: 11px; font-weight: 700; letter-spacing: 1.5px; color: rgba(255,255,255,.3); text-transform: uppercase; margin-bottom: 5px; }\n    .credit-value { font-size: 14px; font-weight: 600; color: rgba(255,255,255,.85); }\n    .credit-sub { font-size: 11px; color: rgba(255,255,255,.35); margin-top: 3px; }\n\n    /* ── TECH BADGES ── */\n    .tech-row {\n      display: flex; flex-wrap: wrap; justify-content: center; gap: 10px;\n      max-width: 700px; margin: 0 auto 48px;\n      animation: fadeInUp .8s .7s ease both;\n    }\n    .tech-badge {\n      display: flex; align-items: center; gap: 7px;\n      background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09);\n      border-radius: 8px; padding: 8px 16px;\n      font-size: 12px; font-weight: 600; color: rgba(255,255,255,.7);\n      transition: .18s;\n    }\n    .tech-badge:hover { border-color: var(--ac); color: var(--ac); transform: scale(1.05); }\n    .tb-dot { width: 8px; height: 8px; border-radius: 50%; }\n\n    /* ── SIGNATURE SECTION ── */\n    .signature-section {\n      text-align: center; margin-bottom: 60px;\n      animation: fadeInUp .8s .8s ease both;\n    }\n    .signature-line {\n      display: inline-block;\n      font-family: 'Fira Code', monospace;\n      font-size: 13px;\n      color: rgba(0,255,204,.6);\n      border-top: 1px solid rgba(0,255,204,.2);\n      padding-top: 14px;\n      letter-spacing: 2px;\n    }\n\n    /* ── NAV ── */\n    nav {\n      position: fixed; top: 0; left: 0; right: 0; z-index: 100;\n      background: rgba(8,8,16,.8); backdrop-filter: blur(16px);\n      border-bottom: 1px solid rgba(255,255,255,.06);\n      padding: 0 24px; height: 56px;\n      display: flex; align-items: center; justify-content: space-between;\n    }\n    .nav-logo { display: flex; align-items: center; gap: 10px; }\n    .nav-logo-text { font-weight: 800; font-size: 15px; letter-spacing: -.3px; }\n    .nav-logo-text span { color: var(--ac); }\n    .nav-logo-ver { font-size: 10px; color: rgba(255,255,255,.3); background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 4px; padding: 2px 6px; }\n    .nav-links { display: flex; align-items: center; gap: 6px; }\n    .nav-link { background: none; border: none; color: rgba(255,255,255,.5); font-size: 13px; font-family: inherit; padding: 6px 12px; border-radius: 6px; cursor: pointer; transition: .14s; text-decoration: none; }\n    .nav-link:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.9); }\n    .nav-cta { background: var(--ac); color: #000; font-weight: 700; font-size: 12px; padding: 7px 16px; border-radius: 7px; border: none; cursor: pointer; font-family: inherit; transition: .18s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }\n    .nav-cta:hover { box-shadow: 0 0 20px rgba(0,255,204,.4); transform: translateY(-1px); }\n\n    /* ── MISSION ── */\n    .section { padding: 80px 20px; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }\n    .section-label { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--ac); margin-bottom: 10px; }\n    .section-title { font-size: clamp(28px, 5vw, 48px); font-weight: 800; line-height: 1.15; letter-spacing: -1px; color: #fff; margin-bottom: 18px; }\n    .section-sub { font-size: 16px; color: rgba(255,255,255,.5); line-height: 1.75; max-width: 640px; }\n\n    /* ── FEATURE TIMELINE ── */\n    .timeline { position: relative; padding-left: 24px; margin-top: 40px; }\n    .timeline::before { content: ''; position: absolute; left: 7px; top: 0; bottom: 0; width: 1px; background: linear-gradient(to bottom, var(--ac), var(--ac2), transparent); }\n    .tl-item { position: relative; margin-bottom: 28px; }\n    .tl-dot { position: absolute; left: -24px; top: 4px; width: 14px; height: 14px; border-radius: 50%; background: var(--ac); box-shadow: 0 0 8px var(--ac); flex-shrink: 0; }\n    .tl-title { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 5px; }\n    .tl-desc { font-size: 13px; color: rgba(255,255,255,.45); line-height: 1.6; }\n    .tl-code { font-family: 'Fira Code', monospace; font-size: 11px; color: var(--ac); background: rgba(0,255,204,.06); border: 1px solid rgba(0,255,204,.15); border-radius: 6px; padding: 6px 12px; margin-top: 8px; display: inline-block; }\n\n    /* ── FOOTER ── */\n    footer {\n      border-top: 1px solid rgba(255,255,255,.06);\n      padding: 30px 24px;\n      text-align: center;\n      font-size: 12px; color: rgba(255,255,255,.25);\n      position: relative; z-index: 1;\n    }\n    footer a { color: var(--ac); text-decoration: none; }\n    footer a:hover { text-decoration: underline; }\n\n    /* Glow BG */\n    .glow-bg {\n      position: fixed; pointer-events: none; z-index: 0;\n      border-radius: 50%; filter: blur(80px); opacity: .12;\n    }\n    .glow1 { width: 600px; height: 600px; background: radial-gradient(circle, var(--ac), transparent); top: -200px; left: -200px; }\n    .glow2 { width: 500px; height: 500px; background: radial-gradient(circle, var(--ac2), transparent); bottom: -150px; right: -150px; }\n    .glow3 { width: 400px; height: 400px; background: radial-gradient(circle, var(--ac3), transparent); top: 50%; left: 50%; transform: translate(-50%,-50%); }\n  </style>\n</head>\n<body>\n\n<div class=\"glow-bg glow1\"></div>\n<div class=\"glow-bg glow2\"></div>\n<div class=\"glow-bg glow3\"></div>\n<canvas id=\"particles\"></canvas>\n\n<!-- NAV -->\n<nav>\n  <div class=\"nav-logo\">\n    <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\">\n      <path d=\"M12 2L2 7L12 12L22 7L12 2Z\" fill=\"#00ffcc\" opacity=\".9\"/>\n      <path d=\"M2 17L12 22L22 17\" stroke=\"#00ffcc\" stroke-width=\"1.5\" fill=\"none\"/>\n      <path d=\"M2 12L12 17L22 12\" stroke=\"#00ffcc\" stroke-width=\"1.5\" fill=\"none\" opacity=\".5\"/>\n    </svg>\n    <span class=\"nav-logo-text\">NAT<span>COM</span></span>\n    <span class=\"nav-logo-ver\">v2.0</span>\n  </div>\n  <div class=\"nav-links\">\n    <a class=\"nav-link\" href=\"index.html\">Studio</a>\n    <a class=\"nav-link\" href=\"#mission\">Mission</a>\n    <a class=\"nav-link\" href=\"#features\">Features</a>\n    <a class=\"nav-cta\" href=\"index.html\">\n      <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M5 3L19 12L5 21V3Z\"/></svg>\n      Open IDE\n    </a>\n  </div>\n</nav>\n\n<!-- HERO -->\n<section class=\"hero\" style=\"padding-top:100px;\">\n  <div class=\"natcom-badge\">\n    <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#00ffcc\" stroke-width=\"2\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>\n    Sovereign Language Creator\n  </div>\n\n  <div class=\"photo-wrapper\">\n    <div class=\"photo-inner\">\n      <img src=\"beon.jpg\" alt=\"Beon Binesh — Creator of NATCOM\">\n    </div>\n    <div class=\"online-dot\"></div>\n  </div>\n\n  <h1 class=\"creator-name\">Beon Binesh</h1>\n  <p class=\"creator-role\">Software Architect · Language Designer · AI Pioneer</p>\n  <p class=\"creator-tagline\">Creator of NATCOM — The World's First English Programming Language</p>\n\n  <div class=\"statement-card\">\n    <h2>\"Code in Plain English. No Syntax. No Barriers.\"</h2>\n    <p>\n      I built <strong>NATCOM</strong> to break the biggest barrier in programming — <strong>syntax</strong>.\n      Why should you need to memorize <code style=\"color:#00ffcc;font-family:'Fira Code',monospace;font-size:13px;\">printf(\"Hello %s\\n\", name);</code> when you can just write\n      <code style=\"color:#00ffcc;font-family:'Fira Code',monospace;font-size:13px;\">Display \"Hello World\".</code> ?<br><br>\n      NATCOM is a <strong>fully compiled, sovereign programming language</strong> built entirely on natural English prose.\n      It compiles to native C (-O3 optimized) and JavaScript, supports user input, math, loops, conditionals,\n      strings, booleans, random numbers — <strong>everything Python and C++ can do, in plain English.</strong>\n    </p>\n  </div>\n\n  <div class=\"credits-grid\">\n    <div class=\"credit-card\">\n      <div class=\"credit-icon\">🤖</div>\n      <div class=\"credit-label\">AI Engine</div>\n      <div class=\"credit-value\">Google Gemini</div>\n      <div class=\"credit-sub\">2.5 Pro / Flash</div>\n    </div>\n    <div class=\"credit-card\">\n      <div class=\"credit-icon\">🚀</div>\n      <div class=\"credit-label\">Development Platform</div>\n      <div class=\"credit-value\">Antigravity (AGY)</div>\n      <div class=\"credit-sub\">Google DeepMind</div>\n    </div>\n    <div class=\"credit-card\">\n      <div class=\"credit-icon\">⚙️</div>\n      <div class=\"credit-label\">Compiler Backend</div>\n      <div class=\"credit-value\">GCC + Python</div>\n      <div class=\"credit-sub\">Native -O3 Binary</div>\n    </div>\n    <div class=\"credit-card\">\n      <div class=\"credit-icon\">🌐</div>\n      <div class=\"credit-label\">IDE Frontend</div>\n      <div class=\"credit-value\">Vanilla JS + CSS</div>\n      <div class=\"credit-sub\">Zero dependencies</div>\n    </div>\n  </div>\n\n  <div class=\"tech-row\">\n    <div class=\"tech-badge\"><div class=\"tb-dot\" style=\"background:#00ffcc\"></div> NATCOM Language (.nc)</div>\n    <div class=\"tech-badge\"><div class=\"tb-dot\" style=\"background:#4ec9b0\"></div> Python 3 Parser</div>\n    <div class=\"tech-badge\"><div class=\"tb-dot\" style=\"background:#f78c6c\"></div> C Codegen (GCC -O3)</div>\n    <div class=\"tech-badge\"><div class=\"tb-dot\" style=\"background:#82aaff\"></div> JavaScript Target</div>\n    <div class=\"tech-badge\"><div class=\"tb-dot\" style=\"background:#c792ea\"></div> Self-Healing Engine</div>\n    <div class=\"tech-badge\"><div class=\"tb-dot\" style=\"background:#ffd700\"></div> Sovereign IDE</div>\n    <div class=\"tech-badge\"><div class=\"tb-dot\" style=\"background:#ff9cac\"></div> Google Gemini AI</div>\n    <div class=\"tech-badge\"><div class=\"tb-dot\" style=\"background:#7c6af7\"></div> Antigravity AGY</div>\n  </div>\n\n  <div class=\"signature-section\">\n    <div class=\"tech-card\">\n      <div class=\"tech-icon\"><i class=\"fas fa-landmark\"></i></div>\n      <h3>A Nod to History: COBOL vs. NATCOM</h3>\n      <p>In 1959, <b>Admiral Grace Hopper</b> created COBOL to make programming accessible in English. While visionary, it required strict margins and heavy boilerplate.</p>\n      <p><b>NATCOM is the modern realization of that dream:</b></p>\n      <ul style=\"text-align: left; opacity: 0.9; margin-top: 10px;\">\n        <li><b>Free-Form:</b> Parses natural English without punishing spacing.</li>\n        <li><b>Modern Architecture:</b> Compiles to Native C/JS with no bloated dependencies.</li>\n        <li><b>Sovereign Bootstrapping:</b> The compiler rebuilds itself natively!</li>\n        <li><b>Zero Barriers:</b> A built-in web IDE perfects the experience.</li>\n      </ul>\n    </div>\n\n    <div class=\"signature-line\">— Developed with ❤️ by Beon Binesh using Google Gemini &amp; Antigravity —</div>\n  </div>\n</section>\n\n<!-- MISSION -->\n<section class=\"section\" id=\"mission\">\n  <div class=\"section-label\">The Mission</div>\n  <h2 class=\"section-title\">English is now a<br>Programming Language.</h2>\n  <p class=\"section-sub\">\n    NATCOM eliminates the divide between human thought and computer execution.\n    Every program is written as natural English sentences — no curly braces, no semicolons, no memorization.\n    Just describe what you want, and NATCOM compiles it to blazing-fast native code.\n  </p>\n</section>\n\n<!-- FEATURES TIMELINE -->\n<section class=\"section\" id=\"features\" style=\"padding-top:0;\">\n  <div class=\"section-label\">Language Features</div>\n  <h2 class=\"section-title\">Everything Python &amp; C++ have.<br>In English.</h2>\n  <div class=\"timeline\">\n    <div class=\"tl-item\">\n      <div class=\"tl-dot\"></div>\n      <div class=\"tl-title\">Variables — Integer, Float, String, Boolean</div>\n      <div class=\"tl-desc\">All primitive types, declared in plain English.</div>\n      <div class=\"tl-code\">Create a high speed integer named Score and set it to 0.</div>\n    </div>\n    <div class=\"tl-item\">\n      <div class=\"tl-dot\" style=\"background:var(--ac2);box-shadow:0 0 8px var(--ac2)\"></div>\n      <div class=\"tl-title\">User Input — Numbers and Text</div>\n      <div class=\"tl-desc\">Interactive programs that accept keyboard input from users.</div>\n      <div class=\"tl-code\">Ask the user to enter a value for Speed.</div>\n    </div>\n    <div class=\"tl-item\">\n      <div class=\"tl-dot\" style=\"background:var(--ac3);box-shadow:0 0 8px var(--ac3)\"></div>\n      <div class=\"tl-title\">Full Math Library</div>\n      <div class=\"tl-desc\">sqrt, abs, floor, ceil, log, exp, pow, max, min, modulo, random.</div>\n      <div class=\"tl-code\">Set Result to the square root of Force.</div>\n    </div>\n    <div class=\"tl-item\">\n      <div class=\"tl-dot\"></div>\n      <div class=\"tl-title\">Loops — Repeat, While, Simulation</div>\n      <div class=\"tl-desc\">All loop patterns supported including game-loop simulation.</div>\n      <div class=\"tl-code\">Repeat 10 times: ... Done.</div>\n    </div>\n    <div class=\"tl-item\">\n      <div class=\"tl-dot\" style=\"background:var(--ac2);box-shadow:0 0 8px var(--ac2)\"></div>\n      <div class=\"tl-title\">Conditionals — If / Otherwise</div>\n      <div class=\"tl-desc\">Branching logic in natural English.</div>\n      <div class=\"tl-code\">If the Score is greater than 100, then: ... Otherwise: ...</div>\n    </div>\n    <div class=\"tl-item\">\n      <div class=\"tl-dot\" style=\"background:var(--ac3);box-shadow:0 0 8px var(--ac3)\"></div>\n      <div class=\"tl-title\">Self-Healing Engine</div>\n      <div class=\"tl-desc\">Live error detection with red squiggles, suggestions, and auto-fix hints.</div>\n      <div class=\"tl-code\">// Error lines highlighted in red with fix suggestions</div>\n    </div>\n    <div class=\"tl-item\">\n      <div class=\"tl-dot\"></div>\n      <div class=\"tl-title\">Multi-Target Compilation</div>\n      <div class=\"tl-desc\">Compile the same .nc file to native C binary or JavaScript for the web.</div>\n      <div class=\"tl-code\">./natcom build app.nc -o app &nbsp;&nbsp;|&nbsp;&nbsp; ./natcom build app.nc --target js -o app.js</div>\n    </div>\n    <div class=\"tl-item\">\n      <div class=\"tl-dot\" style=\"background:var(--ac2);box-shadow:0 0 8px var(--ac2)\"></div>\n      <div class=\"tl-title\">System Override</div>\n      <div class=\"tl-desc\">Drop raw C or JavaScript directly inside your English program.</div>\n      <div class=\"tl-code\">&lt;SYSTEM_OVERRIDE&gt; printf(\"Raw C code here\"); &lt;/SYSTEM_OVERRIDE&gt;</div>\n    </div>\n  </div>\n</section>\n\n<!-- FOOTER -->\n<footer>\n  <p style=\"margin-bottom:8px;\">\n    <strong style=\"color:rgba(255,255,255,.7);\">NATCOM</strong> — Natural Communication Language\n    &nbsp;·&nbsp; v2.0\n    &nbsp;·&nbsp; Compiled with <a href=\"https://ai.google.dev/gemini-api\">Google Gemini</a>\n    &nbsp;·&nbsp; Built on <a href=\"#\">Antigravity AGY</a>\n  </p>\n  <p>© 2026 <strong style=\"color:var(--ac);\">Beon Binesh</strong>. All rights reserved.</p>\n</footer>\n\n<script>\n// ── PARTICLE SYSTEM ──────────────────────────────────────────\nconst canvas = document.getElementById('particles');\nconst ctx    = canvas.getContext('2d');\nlet W, H, particles = [];\n\nfunction resize() {\n  W = canvas.width  = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\nclass Particle {\n  constructor() { this.reset(); }\n  reset() {\n    this.x  = Math.random() * W;\n    this.y  = Math.random() * H;\n    this.vx = (Math.random() - .5) * .3;\n    this.vy = (Math.random() - .5) * .3;\n    this.r  = Math.random() * 1.5 + .3;\n    this.a  = Math.random() * .5 + .1;\n    const colors = ['0,255,204','124,106,247','247,160,106'];\n    this.c  = colors[Math.floor(Math.random() * colors.length)];\n  }\n  update() {\n    this.x += this.vx; this.y += this.vy;\n    if (this.x < 0 || this.x > W || this.y < 0 || this.y > H) this.reset();\n  }\n  draw() {\n    ctx.beginPath();\n    ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);\n    ctx.fillStyle = \`rgba(\${this.c},\${this.a})\`;\n    ctx.fill();\n  }\n}\n\nfor (let i = 0; i < 120; i++) particles.push(new Particle());\n\n// Draw connecting lines\nfunction drawLines() {\n  for (let i = 0; i < particles.length; i++) {\n    for (let j = i + 1; j < particles.length; j++) {\n      const dx = particles[i].x - particles[j].x;\n      const dy = particles[i].y - particles[j].y;\n      const d  = Math.sqrt(dx * dx + dy * dy);\n      if (d < 120) {\n        ctx.beginPath();\n        ctx.moveTo(particles[i].x, particles[i].y);\n        ctx.lineTo(particles[j].x, particles[j].y);\n        ctx.strokeStyle = \`rgba(0,255,204,\${.06 * (1 - d / 120)})\`;\n        ctx.lineWidth = .5;\n        ctx.stroke();\n      }\n    }\n  }\n}\n\nfunction animate() {\n  ctx.clearRect(0, 0, W, H);\n  particles.forEach(p => { p.update(); p.draw(); });\n  drawLines();\n  requestAnimationFrame(animate);\n}\nanimate();\n\n// ── INTERSECTION OBSERVER for animations ──────────────────────\nconst observer = new IntersectionObserver(entries => {\n  entries.forEach(e => {\n    if (e.isIntersecting) {\n      e.target.style.animation = 'fadeInUp .7s ease forwards';\n      observer.unobserve(e.target);\n    }\n  });\n}, { threshold: .15 });\n\ndocument.querySelectorAll('.tl-item, .credit-card').forEach(el => {\n  el.style.opacity = '0';\n  observer.observe(el);\n});\n</script>\n</body>\n</html>\n\n\n\n\nEOF_NATCOM_BOOTSTRAP");
    system("chmod +x natcom");
    printf("[BOOTSTRAP V2] Rebuild Complete. All systems sovereign.\n");
</SYSTEM_OVERRIDE>
